    private int _rsPage = 1;
    private int _rsPerPage = 5;

    private PagedRecordset.Recordset _recordset => BuildRecordset();

    private PagedRecordset.Recordset BuildRecordset()
    {
        var skip = (_rsPage - 1) * _rsPerPage;
        var pageRows = _allRows.Skip(skip).Take(_rsPerPage).Cast<object>().ToList();

        return new PagedRecordset.Recordset
        {
            Records = pageRows,
            TotalRecords = _allRows.Count,
            CurrentPage = _rsPage,
            RecordsPerPage = _rsPerPage,
            TotalPages = (int)Math.Ceiling(_allRows.Count / (double)_rsPerPage),
            Columns = new List<PagedRecordset.Column>
            {
                new() { Label = "Component", DataElementName = "Name" },
                new() { Label = "Type", DataElementName = "Type" },
                new() { Label = "Status", DataElementName = "Status" },
            }
        };
    }

    private void OnRecordsetNav(string changeType, object value)
    {
        if (changeType == "page" && value is int newPage) {
            _rsPage = newPage;
        } else if (changeType == "count" && value is int newCount) {
            _rsPerPage = newCount;
            _rsPage = 1;
        }

        StateHasChanged();
    }

