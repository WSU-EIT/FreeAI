    private Task<List<(string key, string label)>?> SearchCountries(string term)
    {
        var matches = _countries
            .Where(country => country.Contains(term ?? string.Empty, StringComparison.OrdinalIgnoreCase))
            .Select(country => (key: country, label: country))
            .ToList();

        return Task.FromResult<List<(string key, string label)>?>(matches);
    }

