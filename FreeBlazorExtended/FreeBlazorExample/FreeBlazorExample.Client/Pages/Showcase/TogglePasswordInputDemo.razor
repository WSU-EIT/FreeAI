@page "/showcase/togglepassword"

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <h1>Toggle Password Input Component</h1>
            <p class="lead">A password input component with show/hide toggle for secure password entry while allowing users to verify their input.</p>
        </div>
    </div>

    <ShowcaseAbout Kind="component"
        WhatTechnical="A password input with an eye-icon toggle button that switches the underlying input between type='password' and type='text', plus an optional configurable strength indicator that evaluates entropy rules in real time."
        WhatEli5="A password box with a little eye button — click it to check what you're typing without submitting it, so you catch typos before you lock yourself out."
        Who=@(new[]{ "Developers building any login, registration, or password-change form", "UX designers standardising password entry across the app", "Forms with a confirm-password field where users need to visually verify they typed the same thing twice" })
        WhenUse=@(new[]{ "Login forms, registration, password reset, and change-password screens", "Any input of type password where user error on a mobile keyboard is likely", "Forms that need to show password strength feedback during entry" })
        WhenNot=@(new[]{ "Read-only masked display of a stored secret — use a different redaction pattern", "API key display with copy-to-clipboard — a different UX is more appropriate there" })
        Why="Users mistype passwords (especially on mobile) and then can't tell why login failed. The eye toggle costs nothing and saves support calls. Strength feedback during entry catches weak passwords before they're saved."
        TechNotes=@(new[]{ "Toggle implemented by switching the HTML input type attribute; no JS interop needed", "ShowIcon and HideIcon parameters accept any icon class string for full design-system flexibility", "Strength indicator (optional): evaluates length, uppercase, lowercase, digit, and special-char rules; maps to Weak/Fair/Good/Strong/Very Strong + Bootstrap progress-bar color", "MinLength/MaxLength enforce constraints via native HTML attributes and optional Blazor validation", "Disabled parameter disables both the input and the toggle button" })
        QuickFacts=@(new Dictionary<string, string> { ["Layer"] = "UI only", ["Persisted"] = "No", ["Real-time"] = "No", ["Auth required"] = "No", ["Namespace"] = "FreeBlazor" }) />

    <div class="row mb-5">
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header bg-light">
                    <h2 class="h5 mb-0">Basic Password Input</h2>
                </div>
                <div class="card-body">
                    <p class="text-muted small mb-3">Standard password input with show/hide toggle.</p>
                    <label for="basicPassword" class="form-label">Password:</label>
                    <TogglePasswordInput Value="@_basicPassword" OnChange="@((string v) => { _basicPassword = v; StateHasChanged(); })" Placeholder="Enter password..." />
                    @if (!string.IsNullOrEmpty(_basicPassword)) {
                        <div class="alert alert-info mt-3 mb-0" role="alert">
                            <strong>Password strength:</strong> @GetPasswordStrength(_basicPassword)
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card">
                <div class="card-header bg-light">
                    <h2 class="h5 mb-0">Confirm Password</h2>
                </div>
                <div class="card-body">
                    <p class="text-muted small mb-3">Two password inputs for confirmation.</p>
                    <label for="newPassword" class="form-label">New Password:</label>
                    <TogglePasswordInput Value="@_newPassword" OnChange="@((string v) => { _newPassword = v; StateHasChanged(); })" Placeholder="Enter new password..." />

                    <label for="confirmPassword" class="form-label mt-3">Confirm Password:</label>
                    <TogglePasswordInput Value="@_confirmPassword" OnChange="@((string v) => { _confirmPassword = v; StateHasChanged(); })" Placeholder="Confirm password..." />

                    @if (!string.IsNullOrEmpty(_newPassword) && !string.IsNullOrEmpty(_confirmPassword)) {
                        @if (_newPassword == _confirmPassword) {
                            <div class="alert alert-success mt-3 mb-0" role="alert">
                                <i class="fas fa-check-circle me-2"></i>Passwords match!
                            </div>
                        } else {
                            <div class="alert alert-danger mt-3 mb-0" role="alert">
                                <i class="fas fa-times-circle me-2"></i>Passwords do not match
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header bg-light">
                    <h2 class="h5 mb-0">With Strength Indicator</h2>
                </div>
                <div class="card-body">
                    <p class="text-muted small mb-3">Password with real-time strength feedback.</p>
                    <label for="strengthPassword" class="form-label">Create Password:</label>
                    <TogglePasswordInput Value="@_strengthPassword" OnChange="@((string v) => { _strengthPassword = v; StateHasChanged(); })" Placeholder="Enter password..." />

                    <div class="mt-3">
                        <div class="progress" role="progressbar"
                             aria-label="Password strength"
                             aria-valuenow="@GetStrengthPercentage(_strengthPassword)"
                             aria-valuemin="0"
                             aria-valuemax="100"
                             aria-valuetext="@GetPasswordStrength(_strengthPassword)">
                            <div class="progress-bar @GetStrengthClass(_strengthPassword)"
                                style="width: @GetStrengthPercentage(_strengthPassword)%;">
                            </div>
                        </div>
                        <small class="text-muted">
                            Strength: @GetPasswordStrength(_strengthPassword)
                        </small>
                    </div>

                    @if (!string.IsNullOrEmpty(_strengthPassword)) {
                        <div class="mt-3">
                            <p><strong>Password requirements:</strong></p>
                            <ul class="list-unstyled">
                                <li>@PasswordCheck(_strengthPassword.Length >= 8, "8+ characters")</li>
                                <li>@PasswordCheck(System.Text.RegularExpressions.Regex.IsMatch(_strengthPassword, "[A-Z]"), "Uppercase letter")</li>
                                <li>@PasswordCheck(System.Text.RegularExpressions.Regex.IsMatch(_strengthPassword, "[a-z]"), "Lowercase letter")</li>
                                <li>@PasswordCheck(System.Text.RegularExpressions.Regex.IsMatch(_strengthPassword, "[0-9]"), "Number")</li>
                                <li>@PasswordCheck(System.Text.RegularExpressions.Regex.IsMatch(_strengthPassword, "[!@#$%^&*]"), "Special character")</li>
                            </ul>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card">
                <div class="card-header bg-light">
                    <h2 class="h5 mb-0">Login Form</h2>
                </div>
                <div class="card-body">
                    <p class="text-muted small mb-3">Typical login form with password field.</p>
                    <form>
                        <div class="mb-3">
                            <label for="email" class="form-label">Email Address:</label>
                            <input type="email" class="form-control" id="email" placeholder="user@example.com" @bind="@_loginEmail" />
                        </div>

                        <div class="mb-3">
                            <label for="loginPassword" class="form-label">Password:</label>
                            <TogglePasswordInput Value="@_loginPassword" OnChange="@((string v) => { _loginPassword = v; StateHasChanged(); })" Placeholder="Enter password..." />
                        </div>

                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" id="rememberCheck" @bind="@_rememberMe" />
                            <label class="form-check-label" for="rememberCheck">
                                Remember me
                            </label>
                        </div>

                        <button type="button" class="btn btn-primary w-100"
                            disabled="@(string.IsNullOrEmpty(_loginEmail) || string.IsNullOrEmpty(_loginPassword))">
                            Sign In
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header bg-light">
                    <h2 class="h5 mb-0">With Copy Button</h2>
                </div>
                <div class="card-body">
                    <p class="text-muted small mb-3">Password field with built-in copy-to-clipboard button.</p>
                    <label for="copyPassword" class="form-label">API Key / Token:</label>
                    <TogglePasswordInput Value="@_pinPassword" OnChange="@((string v) => { _pinPassword = v; StateHasChanged(); })" Placeholder="Paste your token here..." ShowCopyPasswordButton="true" />
                    <small class="text-muted">Click the copy icon to copy the value to clipboard.</small>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card">
                <div class="card-header bg-light">
                    <h2 class="h5 mb-0">Disabled State</h2>
                </div>
                <div class="card-body">
                    <p class="text-muted small mb-3">Password input in disabled state.</p>
                    <label for="disabledPassword" class="form-label">Password (disabled):</label>
                    <TogglePasswordInput Value="@_disabledPassword" OnChange="@((string v) => { _disabledPassword = v; StateHasChanged(); })" Placeholder="Cannot edit..." Disabled="true" />
                    <div class="form-check mt-3">
                        <input class="form-check-input" type="checkbox" id="enablePasswordCheck"
                            @onchange="@((ChangeEventArgs e) => _passwordDisabled = !(bool)e.Value!)" />
                        <label class="form-check-label" for="enablePasswordCheck">
                            Enable editing
                        </label>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-light">
                    <h2 class="h5 mb-0">Parameter Documentation</h2>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered">
                            <thead class="table-light">
                                <tr>
                                    <th>Parameter</th>
                                    <th>Type</th>
                                    <th>Default</th>
                                    <th>Description</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><code>Value</code></td>
                                    <td>string</td>
                                    <td>-</td>
                                    <td>The password value (use @@bind-Value for two-way binding)</td>
                                </tr>
                                <tr>
                                    <td><code>Placeholder</code></td>
                                    <td>string</td>
                                    <td>-</td>
                                    <td>Placeholder text shown in the input</td>
                                </tr>
                                <tr>
                                    <td><code>Disabled</code></td>
                                    <td>bool</td>
                                    <td>false</td>
                                    <td>Disables both the input and the toggle button</td>
                                </tr>
                                <tr>
                                    <td><code>ShowCopyPasswordButton</code></td>
                                    <td>bool</td>
                                    <td>true</td>
                                    <td>Shows a copy-to-clipboard button next to the toggle</td>
                                </tr>
                                <tr>
                                    <td><code>ShowPassword</code></td>
                                    <td>bool</td>
                                    <td>false</td>
                                    <td>Controls the show/hide password state programmatically</td>
                                </tr>
                                <tr>
                                    <td><code>UseBootstrapInputGroup</code></td>
                                    <td>bool</td>
                                    <td>false</td>
                                    <td>Wraps the input in a Bootstrap input-group for styling</td>
                                </tr>
                                <tr>
                                    <td><code>IconShowPassword</code></td>
                                    <td>string?</td>
                                    <td>-</td>
                                    <td>Icon class for the show-password button</td>
                                </tr>
                                <tr>
                                    <td><code>IconHidePassword</code></td>
                                    <td>string?</td>
                                    <td>-</td>
                                    <td>Icon class for the hide-password button</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-light">
                    <h2 class="h5 mb-0">Usage Example</h2>
                </div>
                <div class="card-body">
                    <pre><code class="language-razor">@@page "/change-password"

&lt;h3&gt;Change Password&lt;/h3&gt;

&lt;div class="mb-3"&gt;
    &lt;label for="currentPassword"&gt;Current Password:&lt;/label&gt;
    &lt;TogglePasswordInput @@bind-Value="@@_currentPassword"
        Placeholder="Enter current password..." /&gt;
&lt;/div&gt;

&lt;div class="mb-3"&gt;
    &lt;label for="newPassword"&gt;New Password:&lt;/label&gt;
    &lt;TogglePasswordInput @@bind-Value="@@_newPassword"
        Placeholder="Enter new password..."
        MinLength="8" /&gt;
&lt;/div&gt;

&lt;div class="mb-3"&gt;
    &lt;label for="confirmPassword"&gt;Confirm Password:&lt;/label&gt;
    &lt;TogglePasswordInput @@bind-Value="@@_confirmPassword"
        Placeholder="Confirm new password..." /&gt;
&lt;/div&gt;

&lt;button class="btn btn-primary" @@onclick="SavePassword"&gt;
    Change Password
&lt;/button&gt;

@@code {{
    private string _currentPassword = "";
    private string _newPassword = "";
    private string _confirmPassword = "";
}}
</code></pre>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-light">
                    <h2 class="h5 mb-0">Accessibility Notes</h2>
                </div>
                <div class="card-body">
                    <ul class="mb-0">
                        <li>Labeled with associated &lt;label&gt; elements for screen readers</li>
                        <li>Toggle button has clear ARIA labels indicating show/hide action</li>
                        <li>Keyboard accessible toggle button</li>
                        <li>Current visibility state is announced to screen readers</li>
                        <li>Visual focus indicators for keyboard users</li>
                        <li>Toggle does not affect form submission security</li>
                        <li>Password field maintains browser password managers support</li>
                        <li>Clear color contrast for all interactive elements</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    protected string _basicPassword = "";
    protected string _newPassword = "";
    protected string _confirmPassword = "";
    protected string _strengthPassword = "";
    protected string _loginEmail = "";
    protected string _loginPassword = "";
    protected string _pinPassword = "";
    protected string _disabledPassword = "SecurePassword123";
    protected bool _rememberMe = false;
    protected bool _passwordDisabled = true;

    protected string GetPasswordStrength(string password)
    {
        if (string.IsNullOrEmpty(password)) return "None";
        int score = 0;
        if (password.Length >= 8) score++;
        if (System.Text.RegularExpressions.Regex.IsMatch(password, "[A-Z]")) score++;
        if (System.Text.RegularExpressions.Regex.IsMatch(password, "[a-z]")) score++;
        if (System.Text.RegularExpressions.Regex.IsMatch(password, "[0-9]")) score++;
        if (System.Text.RegularExpressions.Regex.IsMatch(password, "[!@#$%^&*]")) score++;

        return score switch {
            1 => "Weak",
            2 => "Fair",
            3 => "Good",
            4 => "Strong",
            5 => "Very Strong",
            _ => "Weak"
        };
    }

    protected string GetStrengthClass(string password)
    {
        return GetPasswordStrength(password) switch {
            "Weak" => "bg-danger",
            "Fair" => "bg-warning",
            "Good" => "bg-info",
            "Strong" => "bg-primary",
            "Very Strong" => "bg-success",
            _ => "bg-secondary"
        };
    }

    protected int GetStrengthPercentage(string password)
    {
        return GetPasswordStrength(password) switch {
            "Weak" => 20,
            "Fair" => 40,
            "Good" => 60,
            "Strong" => 80,
            "Very Strong" => 100,
            _ => 0
        };
    }

    protected MarkupString PasswordCheck(bool met, string text)
    {
        string icon = met ? "✓" : "✗";
        string className = met ? "text-success" : "text-danger";
        return new MarkupString($"<span class=\"{className}\"><i class=\"fas {(met ? "fa-check" : "fa-times")}\"></i> {text}</span>");
    }
}
