@page "/showcase/github-repo"
@using FreeBlazorExtended.Components
@using FreeBlazorExtended.GitHubRepoBrowser

<div class="container-fluid py-4">
    <div class="row">
        <div class="col-12">
            <h1>GitHub Repository Browser</h1>
            <p class="lead">
                Browse any public (or private, with a PAT) GitHub repository directly in the browser.
                Expand directories, read source files, and switch branches — all without leaving the app.
            </p>
            <p class="text-muted small">
                The component calls the GitHub REST API v3 from Blazor WASM and renders the full recursive
                file tree with expand/collapse. Text files are decoded from base64 and displayed inline.
                Binary files, symlinks, and oversized files are detected and shown with appropriate notices.
            </p>
        </div>
    </div>

    <div class="row mt-3">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h2 class="card-title h5 mb-0">Interactive Demo</h2>
                </div>
                <div class="card-body">
                    <GitHubRepoBrowser Owner=""
                                       Repo=""
                                       Pat=""
                                       ShowCredentialPanel="true"
                                       OnError="HandleError" />
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-3">
        <div class="col-12">
            <div class="alert alert-info mb-0">
                <strong>💡 Tips</strong>
                <ul class="mb-0 mt-1">
                    <li>For <strong>public repositories</strong>, leave the PAT field empty.</li>
                    <li>
                        For <strong>private repositories</strong>, generate a Personal Access Token at
                        <a href="https://github.com/settings/tokens" target="_blank" rel="noopener noreferrer">
                            github.com/settings/tokens
                        </a>
                        with the <code>repo</code> scope, then paste it in the PAT field.
                    </li>
                    <li>GitHub's unauthenticated API allows <strong>60 requests per hour</strong> per IP. Providing a PAT raises this to 5,000/hour.</li>
                    <li>Very large repositories may have their tree truncated at 100,000 entries by GitHub.</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@code {
    private GitHubBrowseError? _lastError;

    private void HandleError(GitHubBrowseError error)
    {
        _lastError = error;
    }
}
