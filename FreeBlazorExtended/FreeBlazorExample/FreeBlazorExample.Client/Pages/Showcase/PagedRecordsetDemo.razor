@page "/showcase/pagedrecordset"

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <h1>Paged Recordset Component</h1>
            <p class="lead">A component for displaying and paginating through large recordsets with sorting, filtering, and customizable display options.</p>
        </div>
    </div>

    <ShowcaseAbout Kind="component"
        WhatTechnical="A generic paginated table component that accepts a List&lt;T&gt; data source plus column definitions and handles client-side sorting, page navigation, and row-level action callbacks — with optional server-side paging via an async fetch delegate."
        WhatEli5="A data table that only shows one page of results at a time and lets you click column headers to sort — so even a list of 50 000 records feels fast and manageable."
        Who=@(new[]{ "Developers building any admin list view (users, records, reports)", "Anyone replacing a raw HTML table that loads all rows upfront and makes the page slow", "Pages that need sortable columns without writing sort logic for each one" })
        WhenUse=@(new[]{ "Any list of records that could grow beyond ~20 rows", "Admin tables where sortable columns and row actions are needed", "Reports where the user filters down to a subset and pages through results" })
        WhenNot=@(new[]{ "Small static tables (≤10 rows) — the pagination chrome adds visual noise without benefit", "Read-only display tables where interaction is not needed — a plain <table> is lighter" })
        Why="Every list page ends up needing the same pagination logic, sort indicators, and page-size selector. Building it once in a component eliminates that repetition and ensures consistent UX across the app."
        TechNotes=@(new[]{ "Column definitions passed as ColumnDefinition list — specifies header, field accessor, sort key, and optional cell formatter", "Client-side paging: all data loaded once, component slices the page window", "Server-side paging: provide an async FetchData(PageNumber, PageSize, SortColumn, SortDir) delegate; component calls it on navigation", "CheckboxColumn=true adds a selection column; selected items exposed via SelectedItems parameter", "ExtraRowData: optional RenderFragment<T> shown in an expanded row below the main row" })
        QuickFacts=@(new Dictionary<string, string> { ["Layer"] = "UI only", ["Persisted"] = "No", ["Real-time"] = "No", ["Auth required"] = "No", ["Namespace"] = "FreeBlazor" }) />

    <div class="row mb-5">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-light">
                    <h2 class="h5 mb-0">Products Table</h2>
                </div>
                <div class="card-body">
                    <p class="text-muted small mb-3">Paginated product list with sorting and filtering.</p>

                    <div class="mb-3">
                        <div class="input-group">
                            <label for="productSearchInput" class="visually-hidden">Search products</label>
                            <input id="productSearchInput" type="text" class="form-control" placeholder="Search products..."
                                @bind="@_searchTerm" @bind:after="OnSearchChange" />
                            <button class="btn btn-outline-secondary" type="button" aria-label="Search">
                                <i class="fas fa-search" aria-hidden="true"></i>
                            </button>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th @onclick="@(() => SortBy("name"))" style="cursor: pointer;">
                                        Name @if (_sortField == "name") { <i class="fas @(_sortAscending ? "fa-arrow-up" : "fa-arrow-down")"></i> }
                                    </th>
                                    <th @onclick="@(() => SortBy("category"))" style="cursor: pointer;">
                                        Category @if (_sortField == "category") { <i class="fas @(_sortAscending ? "fa-arrow-up" : "fa-arrow-down")"></i> }
                                    </th>
                                    <th @onclick="@(() => SortBy("price"))" style="cursor: pointer;">
                                        Price @if (_sortField == "price") { <i class="fas @(_sortAscending ? "fa-arrow-up" : "fa-arrow-down")"></i> }
                                    </th>
                                    <th>Stock</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var product in _currentPageProducts) {
                                    <tr>
                                        <td>@product.Name</td>
                                        <td>@product.Category</td>
                                        <td>@product.Price.ToString("C")</td>
                                        <td>@product.Stock</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <nav aria-label="Page navigation">
                        <ul class="pagination justify-content-center">
                            <li class="page-item @(_currentPage == 1 ? "disabled" : "")">
                                <button class="page-link" @onclick="@(() => GoToPage(1))">First</button>
                            </li>
                            <li class="page-item @(_currentPage == 1 ? "disabled" : "")">
                                <button class="page-link" @onclick="@(() => GoToPage(_currentPage - 1))">Previous</button>
                            </li>

                            @for (int i = Math.Max(1, _currentPage - 2); i <= Math.Min(_totalPages, _currentPage + 2); i++) {
                                int pageNum = i;
                                <li class="page-item @(_currentPage == pageNum ? "active" : "")">
                                    <button class="page-link" @onclick="@(() => GoToPage(pageNum))">@pageNum</button>
                                </li>
                            }

                            <li class="page-item @(_currentPage == _totalPages ? "disabled" : "")">
                                <button class="page-link" @onclick="@(() => GoToPage(_currentPage + 1))">Next</button>
                            </li>
                            <li class="page-item @(_currentPage == _totalPages ? "disabled" : "")">
                                <button class="page-link" @onclick="@(() => GoToPage(_totalPages))">Last</button>
                            </li>
                        </ul>
                    </nav>

                    <div class="text-center text-muted">
                        <small>
                            Page @_currentPage of @_totalPages |
                            Showing @_currentPageProducts.Count of @_filteredProducts.Count items |
                            Total: @_allProducts.Count items
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-light">
                    <h2 class="h5 mb-0">Users Directory</h2>
                </div>
                <div class="card-body">
                    <p class="text-muted small mb-3">Paginated list with filtering by role.</p>

                    <div class="mb-3">
                        <div class="row">
                            <div class="col-md-6">
                                <label for="userSearchInput" class="form-label">Search by name</label>
                                <input id="userSearchInput" type="text" class="form-control" placeholder="Search by name..."
                                    @bind="@_userSearch" @bind:after="OnUserSearchChange" aria-label="Search users by name" />
                            </div>
                            <div class="col-md-6">
                                <label for="roleFilterSelect" class="form-label">Filter by role</label>
                                <select id="roleFilterSelect" class="form-select" @bind="@_roleFilter" @bind:after="OnRoleFilterChange" aria-label="Filter by role">
                                    <option value="">All Roles</option>
                                    <option value="Admin">Admin</option>
                                    <option value="Manager">Manager</option>
                                    <option value="User">User</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="list-group">
                        @foreach (var user in _currentPageUsers) {
                            <div class="list-group-item">
                                <div class="d-flex w-100 justify-content-between">
                                    <div>
                                        <h3 class="mb-1">@user.Name</h3>
                                        <p class="mb-1 text-muted">@user.Email</p>
                                    </div>
                                    <span class="badge @GetRoleBadgeClass(user.Role)">@user.Role</span>
                                </div>
                            </div>
                        }
                    </div>

                    <nav aria-label="User pagination" class="mt-3">
                        <ul class="pagination justify-content-center">
                            <li class="page-item @(_userPage == 1 ? "disabled" : "")">
                                <button class="page-link" @onclick="@(() => GoToUserPage(_userPage - 1))">Previous</button>
                            </li>
                            <li class="page-item active">
                                <span class="page-link">Page @_userPage</span>
                            </li>
                            <li class="page-item @(_userPage == _userTotalPages ? "disabled" : "")">
                                <button class="page-link" @onclick="@(() => GoToUserPage(_userPage + 1))">Next</button>
                            </li>
                        </ul>
                    </nav>

                    <div class="text-center text-muted">
                        <small>Showing @_currentPageUsers.Count of @_filteredUsers.Count users</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-light">
                    <h2 class="h5 mb-0">Parameter Documentation</h2>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered">
                            <thead class="table-light">
                                <tr>
                                    <th>Feature</th>
                                    <th>Description</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><code>Pagination</code></td>
                                    <td>Navigate through pages of data with customizable page size</td>
                                </tr>
                                <tr>
                                    <td><code>Sorting</code></td>
                                    <td>Click column headers to sort ascending/descending</td>
                                </tr>
                                <tr>
                                    <td><code>Filtering</code></td>
                                    <td>Search and filter records in real-time</td>
                                </tr>
                                <tr>
                                    <td><code>Page Size</code></td>
                                    <td>Configurable number of records per page</td>
                                </tr>
                                <tr>
                                    <td><code>Total Count</code></td>
                                    <td>Display total and current record counts</td>
                                </tr>
                                <tr>
                                    <td><code>Multi-Column Sort</code></td>
                                    <td>Option to sort by multiple columns simultaneously</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-light">
                    <h2 class="h5 mb-0">Usage Example</h2>
                </div>
                <div class="card-body">
                    <pre><code class="language-razor">@@page "/records"

&lt;PagedRecordset @@bind-Records="@@_records"
    PageSize="10"
    OnPageChanged="@@OnPageChange"
    OnSortChanged="@@OnSortChange" /&gt;

@@code {{
    private List&lt;RecordModel&gt; _records = new();
    private int _pageSize = 10;

    protected override async Task OnInitializedAsync()
    {{
        await LoadRecords();
    }}

    private async Task LoadRecords()
    {{
        _records = await FetchRecords();
    }}

    private void OnPageChange(int pageNumber)
    {{
        // Handle page change
    }}

    private void OnSortChange(string sortField, bool ascending)
    {{
        // Handle sort change
    }}
}}
</code></pre>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-light">
                    <h2 class="h5 mb-0">Accessibility Notes</h2>
                </div>
                <div class="card-body">
                    <ul class="mb-0">
                        <li>Table markup uses proper semantic HTML (thead, tbody, th, td)</li>
                        <li>Pagination buttons are keyboard accessible with clear labels</li>
                        <li>Sort buttons announce their function and current direction</li>
                        <li>Current page is indicated with aria-current="page"</li>
                        <li>Filter inputs have associated labels</li>
                        <li>Record count is announced for context</li>
                        <li>Visual focus indicators for keyboard navigation</li>
                        <li>Large click targets (buttons at least 44x44px)</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    // Products data
    protected List<ProductModel> _allProducts = new();
    protected List<ProductModel> _filteredProducts = new();
    protected List<ProductModel> _currentPageProducts = new();
    protected int _currentPage = 1;
    protected int _pageSize = 5;
    protected int _totalPages = 1;
    protected string _searchTerm = "";
    protected string _sortField = "";
    protected bool _sortAscending = true;

    // Users data
    protected List<UserModel> _allUsers = new();
    protected List<UserModel> _filteredUsers = new();
    protected List<UserModel> _currentPageUsers = new();
    protected int _userPage = 1;
    protected int _userPageSize = 3;
    protected int _userTotalPages = 1;
    protected string _userSearch = "";
    protected string _roleFilter = "";

    protected override void OnInitialized()
    {
        InitializeProducts();
        InitializeUsers();
        UpdateProductsDisplay();
        UpdateUsersDisplay();
    }

    protected void InitializeProducts()
    {
        _allProducts = new() {
            new ProductModel { Name = "Laptop", Category = "Electronics", Price = 999.99m, Stock = 15 },
            new ProductModel { Name = "Mouse", Category = "Electronics", Price = 29.99m, Stock = 50 },
            new ProductModel { Name = "Keyboard", Category = "Electronics", Price = 79.99m, Stock = 30 },
            new ProductModel { Name = "Monitor", Category = "Electronics", Price = 299.99m, Stock = 10 },
            new ProductModel { Name = "Desk Chair", Category = "Furniture", Price = 199.99m, Stock = 20 },
            new ProductModel { Name = "Desk Lamp", Category = "Lighting", Price = 49.99m, Stock = 25 },
            new ProductModel { Name = "Webcam", Category = "Electronics", Price = 89.99m, Stock = 18 },
            new ProductModel { Name = "USB Hub", Category = "Electronics", Price = 39.99m, Stock = 40 },
            new ProductModel { Name = "Headphones", Category = "Electronics", Price = 149.99m, Stock = 22 },
            new ProductModel { Name = "Microphone", Category = "Electronics", Price = 119.99m, Stock = 12 },
            new ProductModel { Name = "Desk", Category = "Furniture", Price = 349.99m, Stock = 8 },
            new ProductModel { Name = "Bookshelf", Category = "Furniture", Price = 129.99m, Stock = 14 }
        };
    }

    protected void InitializeUsers()
    {
        _allUsers = new() {
            new UserModel { Name = "Alice Johnson", Email = "alice@example.com", Role = "Admin" },
            new UserModel { Name = "Bob Smith", Email = "bob@example.com", Role = "Manager" },
            new UserModel { Name = "Charlie Brown", Email = "charlie@example.com", Role = "User" },
            new UserModel { Name = "Diana Prince", Email = "diana@example.com", Role = "Admin" },
            new UserModel { Name = "Eve Davis", Email = "eve@example.com", Role = "User" },
            new UserModel { Name = "Frank Miller", Email = "frank@example.com", Role = "Manager" },
            new UserModel { Name = "Grace Lee", Email = "grace@example.com", Role = "User" },
            new UserModel { Name = "Henry Wilson", Email = "henry@example.com", Role = "User" }
        };
    }

    protected void OnSearchChange()
    {
        _currentPage = 1;
        UpdateProductsDisplay();
    }

    protected void SortBy(string field)
    {
        if (_sortField == field) {
            _sortAscending = !_sortAscending;
        } else {
            _sortField = field;
            _sortAscending = true;
        }
        _currentPage = 1;
        UpdateProductsDisplay();
    }

    protected void GoToPage(int pageNum)
    {
        if (pageNum >= 1 && pageNum <= _totalPages) {
            _currentPage = pageNum;
            UpdateProductsDisplay();
        }
    }

    protected void UpdateProductsDisplay()
    {
        _filteredProducts = _allProducts
            .Where(p => string.IsNullOrEmpty(_searchTerm) ||
                       p.Name.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase))
            .ToList();

        if (!string.IsNullOrEmpty(_sortField)) {
            _filteredProducts = _sortField switch {
                "name" => _sortAscending ? _filteredProducts.OrderBy(p => p.Name).ToList() : _filteredProducts.OrderByDescending(p => p.Name).ToList(),
                "category" => _sortAscending ? _filteredProducts.OrderBy(p => p.Category).ToList() : _filteredProducts.OrderByDescending(p => p.Category).ToList(),
                "price" => _sortAscending ? _filteredProducts.OrderBy(p => p.Price).ToList() : _filteredProducts.OrderByDescending(p => p.Price).ToList(),
                _ => _filteredProducts
            };
        }

        _totalPages = (int)Math.Ceiling((double)_filteredProducts.Count / _pageSize);
        _currentPage = Math.Max(1, Math.Min(_currentPage, _totalPages));

        _currentPageProducts = _filteredProducts
            .Skip((_currentPage - 1) * _pageSize)
            .Take(_pageSize)
            .ToList();
    }

    protected void OnUserSearchChange()
    {
        _userPage = 1;
        UpdateUsersDisplay();
    }

    protected void OnRoleFilterChange()
    {
        _userPage = 1;
        UpdateUsersDisplay();
    }

    protected void GoToUserPage(int pageNum)
    {
        if (pageNum >= 1 && pageNum <= _userTotalPages) {
            _userPage = pageNum;
            UpdateUsersDisplay();
        }
    }

    protected void UpdateUsersDisplay()
    {
        _filteredUsers = _allUsers
            .Where(u => (string.IsNullOrEmpty(_userSearch) ||
                        u.Name.Contains(_userSearch, StringComparison.OrdinalIgnoreCase) ||
                        u.Email.Contains(_userSearch, StringComparison.OrdinalIgnoreCase)) &&
                       (string.IsNullOrEmpty(_roleFilter) || u.Role == _roleFilter))
            .ToList();

        _userTotalPages = (int)Math.Ceiling((double)_filteredUsers.Count / _userPageSize);
        _userPage = Math.Max(1, Math.Min(_userPage, _userTotalPages));

        _currentPageUsers = _filteredUsers
            .Skip((_userPage - 1) * _userPageSize)
            .Take(_userPageSize)
            .ToList();
    }

    protected string GetRoleBadgeClass(string role)
    {
        return role switch {
            "Admin" => "bg-danger text-white",
            "Manager" => "bg-warning text-dark",
            "User" => "bg-primary text-white",
            _ => "bg-secondary text-white"
        };
    }

    protected class ProductModel
    {
        public string Name { get; set; } = "";
        public string Category { get; set; } = "";
        public decimal Price { get; set; }
        public int Stock { get; set; }
    }

    protected class UserModel
    {
        public string Name { get; set; } = "";
        public string Email { get; set; } = "";
        public string Role { get; set; } = "";
    }
}
