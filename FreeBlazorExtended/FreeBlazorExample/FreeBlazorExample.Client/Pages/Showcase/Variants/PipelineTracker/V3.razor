@page "/showcase/pipelinetracker/v3"
@using FreeBlazorExtended.PipelineTracker

<div class="container-fluid py-4">
    <h1>Order Tracker With Details Panel</h1>

    <div class="d-flex flex-wrap gap-2 mb-3">
        <button type="button" class="btn btn-primary btn-sm" @onclick="AdvanceStage">Advance Stage</button>
        <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="ResetTracker">Reset to 0</button>
        <button type="button" class="btn btn-outline-warning btn-sm" @onclick="MarkStageSkipped">Mark Stage 3 Skipped</button>
    </div>

    <PipelineTracker Stages="_stages"
                     CurrentStageIndex="@_current"
                     ShowDetailsPanel="true"
                     @bind-SelectedStageIndex="_selected"
                     OnStageClick="HandleClick" />

    <div class="card shadow-sm mt-3">
        <div class="card-body">
            <h2 class="h5">Click Log</h2>
            <ul class="small mb-0 ps-3">
                @foreach (var entry in _clickLog) {
                    <li>@entry</li>
                }
            </ul>
        </div>
    </div>
</div>

@code {
    private int _current = 1;
    private int? _selected = 1;
    private List<PipelineTracker.PipelineStage> _stages = CreateStages();
    private List<string> _clickLog = new() { "No stage clicks yet." };

    private static List<PipelineTracker.PipelineStage> CreateStages()
    {
        return new List<PipelineTracker.PipelineStage>
        {
            new() { Id = "order", Name = "Order Placed", Description = "The customer submitted the order.", Icon = "fa-solid fa-cart-shopping", CompletedAt = DateTime.Now.AddHours(-6), CompletedBy = "Customer" },
            new() { Id = "prep", Name = "Preparing", Description = "The warehouse is preparing the shipment.", Icon = "fa-solid fa-box-open", CompletedAt = DateTime.Now.AddHours(-4), CompletedBy = "Fulfillment" },
            new() { Id = "quality", Name = "Quality Check", Description = "A final inspection step before dispatch.", Icon = "fa-solid fa-clipboard-check", Notes = "Packaging verified." },
            new() { Id = "delivery", Name = "Out for Delivery", Description = "The carrier is delivering the package.", Icon = "fa-solid fa-truck" },
            new() { Id = "done", Name = "Delivered", Description = "Delivery completed.", Icon = "fa-solid fa-house" },
        };
    }

    private Task HandleClick(int index)
    {
        if (_clickLog.Count == 1 && _clickLog[0] == "No stage clicks yet.") {
            _clickLog.Clear();
        }

        _clickLog.Insert(0, $"{DateTime.Now:HH:mm:ss} — clicked stage {index + 1}");
        if (_clickLog.Count > 6) {
            _clickLog = _clickLog.Take(6).ToList();
        }

        return Task.CompletedTask;
    }

    private void AdvanceStage()
    {
        if (_current < _stages.Count - 1) {
            _current++;
            _selected = _current;
        }
    }

    private void ResetTracker()
    {
        _current = 0;
        _selected = 0;
        _stages = CreateStages();
        _clickLog = new List<string> { "Tracker reset." };
    }

    private void MarkStageSkipped()
    {
        if (_stages.Count > 2) {
            _stages[2].State = PipelineTracker.PipelineStageState.Skipped;
            _selected = 2;
        }
    }
}