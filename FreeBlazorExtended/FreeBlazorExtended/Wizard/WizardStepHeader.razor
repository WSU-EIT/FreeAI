@*
    WizardStepHeader — card-header bar for a single wizard step, with a step badge, title,
    and a configurable set of navigation buttons (Back, Next, Finish, Start Over).

    Place one instance at the top of each wizard step card. Wire the navigation callbacks
    to the parent wizard state and set ShowBack / ShowNext / ShowFinish per step.

    Required parameters:
        Title      — the step name shown next to the badge.

    Optional parameters:
        StepNumber      — displayed as "Step N" when no BadgeIcon is set.           Default: 0
        HeaderClass     — Bootstrap classes for the card-header background/text.    Default: "bg-dark text-white"
        ShowSpinner     — replaces the badge with an animated spinner.               Default: false
        SpinnerText     — visually-hidden label for the spinner (accessibility).     Default: "Loading..."
        BadgeIcon       — Font Awesome icon class; overrides the Step-N fallback.   Default: ""
        BadgeClass      — Bootstrap badge classes applied to the icon badge.         Default: "bg-light text-success"
        ShowStartOver   — renders a Start Over button.                               Default: false
        ShowBack        — renders a Back button.                                     Default: false
        ShowNext        — renders a Next button.                                     Default: false
        ShowFinish      — renders a Finish/Submit button.                            Default: false
        NextButtonText  — label for the Next button.                                Default: "Next"
        FinishButtonText— label for the Finish button.                              Default: "Finish"
        InfoText        — supplemental note rendered as muted small text.            Default: ""
        IsDisabled      — disables all buttons (use during async operations).        Default: false
        NextDisabled    — disables only the Next button (e.g. step incomplete).     Default: false
        OnStartOver     — invoked when the user clicks Start Over.
        OnBack          — invoked when the user clicks Back.
        OnNext          — invoked when the user clicks Next.
        OnFinish        — invoked when the user clicks Finish.
*@

<div class="card-header @HeaderClass d-flex justify-content-between align-items-center flex-wrap gap-2 py-3">
    <div class="d-flex align-items-center gap-2">
        @if (ShowSpinner) {
            <div class="spinner-border spinner-border-sm" role="status">
                <span class="visually-hidden">@SpinnerText</span>
            </div>
        } else if (!string.IsNullOrWhiteSpace(BadgeIcon)) {
            <span class="badge @BadgeClass"><i class="fa @BadgeIcon" aria-hidden="true"></i></span>
        } else {
            <span class="badge bg-secondary">Step @StepNumber</span>
        }
        <span class="fw-semibold">@Title</span>
    </div>
    <div class="d-flex gap-2">
        @if (ShowStartOver) {
            <button class="btn btn-outline-light btn-sm" @onclick="OnStartOver" disabled="@IsDisabled"
                    aria-label="Start the wizard over from the beginning">
                <i class="fa fa-refresh me-1" aria-hidden="true"></i> Start Over
            </button>
        }
        @if (ShowBack) {
            <button class="btn btn-secondary btn-sm" @onclick="OnBack" disabled="@IsDisabled"
                    aria-label="Go back to previous step">
                <i class="fa fa-arrow-left me-1" aria-hidden="true"></i> Back
            </button>
        }
        @if (ShowNext) {
            <button class="btn btn-primary btn-sm" @onclick="OnNext" disabled="@(IsDisabled || NextDisabled)"
                    aria-label="@(NextDisabled ? "Complete this step before continuing" : "Continue to next step")">
                @NextButtonText <i class="fa fa-arrow-right ms-1" aria-hidden="true"></i>
            </button>
        }
        @if (ShowFinish) {
            <button class="btn btn-success btn-sm" @onclick="OnFinish" disabled="@IsDisabled"
                    aria-label="Submit and finish the wizard">
                <i class="fa fa-check me-1" aria-hidden="true"></i> @FinishButtonText
            </button>
        }
        @if (!string.IsNullOrWhiteSpace(InfoText)) {
            <span class="text-muted small" role="note">@InfoText</span>
        }
    </div>
</div>

@code {
    [Parameter] public string HeaderClass { get; set; } = "bg-dark text-white";
    [Parameter] public int StepNumber { get; set; }
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public bool ShowSpinner { get; set; }
    [Parameter] public string SpinnerText { get; set; } = "Loading...";
    [Parameter] public string BadgeIcon { get; set; } = "";
    [Parameter] public string BadgeClass { get; set; } = "bg-light text-success";
    [Parameter] public bool ShowStartOver { get; set; }
    [Parameter] public bool ShowBack { get; set; }
    [Parameter] public bool ShowNext { get; set; }
    [Parameter] public bool ShowFinish { get; set; }
    [Parameter] public string NextButtonText { get; set; } = "Next";
    [Parameter] public string FinishButtonText { get; set; } = "Finish";
    [Parameter] public string InfoText { get; set; } = "";
    [Parameter] public bool IsDisabled { get; set; }
    [Parameter] public bool NextDisabled { get; set; }
    [Parameter] public EventCallback OnStartOver { get; set; }
    [Parameter] public EventCallback OnBack { get; set; }
    [Parameter] public EventCallback OnNext { get; set; }
    [Parameter] public EventCallback OnFinish { get; set; }
}
