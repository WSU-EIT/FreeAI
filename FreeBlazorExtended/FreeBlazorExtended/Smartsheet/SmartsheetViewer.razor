@*
    Component: SmartsheetViewer
    Namespace: FreeBlazorExtended.Components
    Purpose: Browse and display Smartsheet sheets.
             The user enters their API token once in the connect panel — it is POSTed
             to /api/Showcase/Smartsheet/connect (HTTPS) and immediately cleared from
             component state. All subsequent data requests use the HttpOnly session cookie
             set by the server. Tokens never appear in GET URLs or response bodies.
    Depends:  HttpClient (registered in WASM program), server SmartsheetController
*@
@namespace FreeBlazorExtended.Components
@using FreeBlazorExtended.Smartsheet
@using System.Net.Http.Json
@using System.Text.Json
@inject HttpClient Http
@implements IDisposable

@* =========================================================
   TOKEN INPUT — shown only when not yet connected
   Token is cleared from memory immediately after POST.
   ========================================================= *@
@if (!_connected)
{
    <div class="card mb-3">
        <div class="card-body">
            <h6 class="card-title mb-3">Connect to Smartsheet</h6>
            <div class="input-group">
                <input type="password"
                       class="form-control"
                       @bind="_tokenInput"
                       placeholder="Smartsheet API Token" />
                <button class="btn btn-primary"
                        @onclick="ConnectAsync"
                        disabled="@_loadingSheets">
                    @if (_loadingSheets)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                        <span>Connecting…</span>
                    }
                    else
                    {
                        <span>Connect</span>
                    }
                </button>
            </div>
            <small class="text-muted mt-1 d-block">
                Your token is sent securely to the server and never stored in the browser.
            </small>
        </div>
    </div>
}
else if (_connectedEmail is not null)
{
    <div class="alert alert-success py-2 mb-3 d-flex align-items-center gap-2">
        <span>&#10003; Connected as <strong>@_connectedEmail</strong></span>
    </div>
}

@* =========================================================
   ERROR DISPLAY
   ========================================================= *@
@if (_errorMessage is not null)
{
    <div class="alert alert-danger alert-dismissible" role="alert">
        <strong>Error:</strong> @_errorMessage
        <button type="button" class="btn-close" aria-label="Dismiss"
                @onclick="() => _errorMessage = null"></button>
    </div>
}

@* =========================================================
   SHEET LIST — shown after sheets loaded, before one selected
   ========================================================= *@
@if (_sheets.Count > 0 && _selectedSheet is null && !_loadingSheet)
{
    <div class="mb-3">
        <h6 class="mb-2">
            Select a sheet
            <span class="badge bg-secondary ms-1">@_sheets.Count</span>
        </h6>
        <div class="list-group">
            @foreach (var sheet in _sheets)
            {
                <button type="button"
                        class="list-group-item list-group-item-action"
                        @onclick="() => LoadSheetAsync(sheet.Id)">
                    <span class="ss-sheet-name">@sheet.Name</span>
                    @if (sheet.ModifiedAt.HasValue)
                    {
                        <small class="text-muted ms-2">
                            Modified @sheet.ModifiedAt.Value.ToLocalTime().ToString("g")
                        </small>
                    }
                </button>
            }
        </div>
    </div>
}

@* =========================================================
   LOADING PROGRESS — shown while fetching sheet rows
   ========================================================= *@
@if (_loadingSheet)
{
    <div class="my-3">
        <p class="mb-1 text-muted small">
            Loading rows… page @_loadedPages of @_totalPages
        </p>
        <div class="progress" role="progressbar"
             aria-valuenow="@_loadedPages" aria-valuemin="0" aria-valuemax="@_totalPages">
            <div class="progress-bar progress-bar-striped progress-bar-animated"
                 style="width: @(_totalPages > 0 ? (_loadedPages * 100 / _totalPages) : 0)%">
            </div>
        </div>
    </div>
}

@* =========================================================
   SHEET DETAIL — shown once a sheet is selected and loaded
   ========================================================= *@
@if (_selectedSheet is not null && !_loadingSheet)
{
    var visibleColumns = _selectedSheet.Columns.Where(c => !c.Hidden).ToList();

    <div class="mb-2 d-flex align-items-center gap-2">
        <button class="btn btn-sm btn-outline-secondary" @onclick="BackToList">
            &#8592; Back
        </button>
        <h4 class="mb-0 ss-sheet-name">@_selectedSheet.Name</h4>
        <span class="badge bg-primary">
            @(_selectedSheet.TotalRowCount ?? _selectedSheet.Rows.Count) rows
        </span>
        @if (_selectedSheet.Permalink is not null)
        {
            <a href="@_selectedSheet.Permalink"
               target="_blank"
               rel="noopener noreferrer"
               class="btn btn-sm btn-outline-primary ms-auto">
                Open in Smartsheet ↗
            </a>
        }
    </div>

    <div class="ss-table-container">
        <table class="table table-sm table-striped table-bordered mb-0">
            <thead class="table-dark sticky-top">
                <tr>
                    @foreach (var col in visibleColumns)
                    {
                        <th scope="col">@col.Title</th>
                    }
                </tr>
            </thead>
            <tbody>
                @if ((_selectedSheet.TotalRowCount ?? _selectedSheet.Rows.Count) > 200)
                {
                    <Virtualize Items="_selectedSheet.Rows" Context="row">
                        <tr>
                            @foreach (var col in visibleColumns)
                            {
                                var cell = row.Cells.FirstOrDefault(c => c.ColumnId == col.Id);
                                <td>@(cell is null ? "" : RenderCell(cell))</td>
                            }
                        </tr>
                    </Virtualize>
                }
                else
                {
                    @foreach (var row in _selectedSheet.Rows)
                    {
                        <tr>
                            @foreach (var col in visibleColumns)
                            {
                                var cell = row.Cells.FirstOrDefault(c => c.ColumnId == col.Id);
                                <td>@(cell is null ? "" : RenderCell(cell))</td>
                            }
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
}

@code {
    // ---------------------------------------------------------------
    // Parameters
    // ---------------------------------------------------------------
    // NOTE: ApiToken parameter intentionally removed — tokens must not be
    // passed as component parameters (visible in Blazor state / devtools).
    // Use the inline connect panel to supply credentials.
    [Parameter] public long?  SheetId       { get; set; }
    [Parameter] public int    RowPageSize   { get; set; } = 500;
    [Parameter] public EventCallback<SmartsheetSheet> OnSheetSelected { get; set; }
    [Parameter] public EventCallback<Exception>        OnError         { get; set; }

    // ---------------------------------------------------------------
    // Private state
    // ---------------------------------------------------------------
    // _tokenInput holds the raw value only until it is POSTed to the server.
    // It is cleared immediately after a successful connect call.
    private string _tokenInput  = "";
    private bool   _connected   = false;
    private string? _connectedEmail;

    private List<SmartsheetSheet> _sheets = [];
    private SmartsheetSheet? _selectedSheet;
    private Dictionary<long, SmartsheetColumn> _columnById = [];
    private bool _loadingSheets;
    private bool _loadingSheet;
    private int  _loadedPages;
    private int  _totalPages;
    private string? _errorMessage;
    private CancellationTokenSource _cts = new();

    // ---------------------------------------------------------------
    // Lifecycle
    // ---------------------------------------------------------------
    protected override async Task OnInitializedAsync()
    {
        // If the user already has an active session cookie, try to load sheets immediately
        await TryLoadExistingSessionAsync();

        if (_connected && SheetId.HasValue)
            await LoadSheetAsync(SheetId.Value);
    }

    // ---------------------------------------------------------------
    // Actions
    // ---------------------------------------------------------------

    private async Task TryLoadExistingSessionAsync()
    {
        // Attempt a sheets fetch — if the server returns 401, no active session
        try
        {
            var resp = await Http.GetAsync("/api/Showcase/Smartsheet/sheets", _cts.Token);
            if (resp.IsSuccessStatusCode)
            {
                _sheets = await resp.Content.ReadFromJsonAsync<List<SmartsheetSheet>>(_cts.Token) ?? [];
                _connected = true;
            }
        }
        catch (TaskCanceledException) { }
        catch { /* No active session — show connect panel */ }
    }

    /// <summary>
    /// POSTs the token to the server connect endpoint, then immediately clears
    /// the in-memory copy. All subsequent calls use the HttpOnly session cookie.
    /// </summary>
    private async Task ConnectAsync()
    {
        if (string.IsNullOrWhiteSpace(_tokenInput))
            return;

        _loadingSheets = true;
        _errorMessage  = null;
        try
        {
            // Send token to server — cookie is set in the response
            var connectResp = await Http.PostAsJsonAsync(
                "/api/Showcase/Smartsheet/connect",
                new { token = _tokenInput },
                _cts.Token);

            // Immediately clear the token from component state
            _tokenInput = "";

            if (!connectResp.IsSuccessStatusCode)
            {
                var err = await connectResp.Content.ReadFromJsonAsync<ServerError>(_cts.Token);
                _errorMessage = err?.Error ?? $"Server returned {(int)connectResp.StatusCode}.";
                return;
            }

            var info = await connectResp.Content.ReadFromJsonAsync<ConnectResult>(_cts.Token);
            _connectedEmail = info?.Email;
            _connected = true;

            // Now fetch the sheet list using the new session cookie
            var sheetsResp = await Http.GetFromJsonAsync<List<SmartsheetSheet>>(
                "/api/Showcase/Smartsheet/sheets", _cts.Token);
            _sheets = sheetsResp ?? [];
        }
        catch (TaskCanceledException) { }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            await OnError.InvokeAsync(ex);
        }
        finally
        {
            _loadingSheets = false;
        }
    }

    private async Task LoadSheetAsync(long sheetId)
    {
        _loadingSheet = true;
        _loadedPages  = 0;
        _totalPages   = 1;
        _errorMessage = null;

        try
        {
            // Fetch page 1 to learn total page count and get columns
            var firstPage = await Http.GetFromJsonAsync<SmartsheetSheet>(
                $"/api/Showcase/Smartsheet/sheets/{sheetId}?pageSize={RowPageSize}&page=1", _cts.Token);
            if (firstPage is null) { _errorMessage = "Empty response from server."; return; }

            _totalPages  = firstPage.TotalPages ?? 1;
            _loadedPages = 1;
            StateHasChanged();

            // Fetch remaining pages and merge rows
            for (int p = 2; p <= _totalPages; p++)
            {
                _cts.Token.ThrowIfCancellationRequested();
                var page = await Http.GetFromJsonAsync<SmartsheetSheet>(
                    $"/api/Showcase/Smartsheet/sheets/{sheetId}?pageSize={RowPageSize}&page={p}", _cts.Token);
                if (page is not null) firstPage.Rows.AddRange(page.Rows);
                _loadedPages = p;
                StateHasChanged();
            }

            _selectedSheet = firstPage;
            _columnById    = (firstPage.Columns ?? []).ToDictionary(c => c.Id);
            await OnSheetSelected.InvokeAsync(_selectedSheet);
        }
        catch (TaskCanceledException) { }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            await OnError.InvokeAsync(ex);
        }
        finally
        {
            _loadingSheet = false;
        }
    }

    private void BackToList()
    {
        _selectedSheet = null;
        _columnById    = [];
    }

    // ---------------------------------------------------------------
    // Cell rendering
    // ---------------------------------------------------------------
    private string RenderCell(SmartsheetCell cell)
    {
        if (!_columnById.TryGetValue(cell.ColumnId, out var col))
            return cell.DisplayValue ?? "";

        return col.Type switch
        {
            "CHECKBOX" => cell.Value?.ValueKind == JsonValueKind.True ? "✓" : "✗",
            _ => cell.DisplayValue
                ?? (cell.Value?.ValueKind == JsonValueKind.String
                    ? cell.Value.Value.GetString() ?? ""
                    : cell.Value?.ToString() ?? "")
        };
    }

    // ---------------------------------------------------------------
    // IDisposable — cancel pending requests, call disconnect
    // ---------------------------------------------------------------
    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
        // Fire-and-forget: tell server to clear the session (best-effort)
        _ = Http.DeleteAsync("/api/Showcase/Smartsheet/disconnect");
    }

    // ---------------------------------------------------------------
    // Response DTOs (server-side shapes)
    // ---------------------------------------------------------------
    private record ConnectResult(bool Connected, string? Email);
    private record ServerError(string? Error);
}
