@*
    FormSection — Foundation fieldset wrapper that groups related form controls under a titled,
    optionally described section with flexible column layout support.

    Use this component to divide long forms into logical groups (e.g. "Contact details",
    "Billing address", "Preferences") so the user can scan and understand structure at a glance.
    The rendered element is a semantic <fieldset>, which assistive technologies expose correctly.

    Required parameters: none — all have sensible defaults.

    Optional parameters:
        Title        — section heading rendered as a <legend>
        Description  — muted guidance line below the title
        Layout       — control arrangement: "stack" (default, vertical) | "grid-2" | "grid-3"
        NoBorder     — strips the card-style border and background for a flat layout
        Compact      — reduces padding for use inside modals or tight panels
        Highlighted  — applies a primary-colour border and tint to draw attention
        ChildContent — the form fields (inputs, selects, etc.)
        FooterContent — render fragment for section-level action buttons or helper links

    Example (two-column address group):
        <FormSection Title="Shipping Address" Layout="grid-2">
            <InputText @bind-Value="Address.Street" />
            <InputText @bind-Value="Address.City" />
            <InputText @bind-Value="Address.State" />
            <InputText @bind-Value="Address.Zip" />
        </FormSection>
*@
@namespace FreeBlazorExtended.Components

<fieldset class="form-section @_sectionClass">
    @if (!String.IsNullOrWhiteSpace(Title)) {
        <legend class="form-section-title">@Title</legend>
    }

    @if (!String.IsNullOrWhiteSpace(Description)) {
        <p class="form-section-description">@Description</p>
    }

    <div class="form-section-content">
        @if (ChildContent != null) {
            @ChildContent
        }
    </div>

    @if (FooterContent != null) {
        <div class="form-section-footer">
            @FooterContent
        </div>
    }
</fieldset>

<style>
    .form-section {
        border: none;
        margin: 0;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
        background-color: var(--bs-light);
        border: 1px solid var(--bs-border-color);
        border-radius: 0.375rem;
    }

    .form-section.no-border {
        background-color: transparent;
        border: none;
        padding: 1rem 0;
    }

    .form-section.compact {
        padding: 1rem;
        margin-bottom: 1rem;
    }

    .form-section.highlighted {
        border-color: var(--bs-primary);
        background-color: rgba(13, 110, 253, 0.05);
    }

    .form-section-title {
        margin: 0 0 0.5rem 0;
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--bs-body-color);
        display: block;
    }

    .form-section-description {
        margin: 0 0 1rem 0;
        font-size: 0.9rem;
        color: var(--bs-secondary);
        line-height: 1.5;
    }

    .form-section-content {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .form-section-content.grid-2 {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
    }

    .form-section-content.grid-3 {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
    }

    .form-section-footer {
        margin-top: 1.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--bs-border-color);
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    @@media (max-width: 768px) {
        .form-section {
            padding: 1rem;
            margin-bottom: 1rem;
        }

        .form-section-content.grid-2,
        .form-section-content.grid-3 {
            grid-template-columns: 1fr;
        }

        .form-section-footer {
            flex-direction: column;
        }

        .form-section-footer button,
        .form-section-footer a {
            width: 100%;
        }
    }
</style>

@code {
    protected string _sectionClass = "";

    /// <summary>
    /// Heading rendered as a <c>&lt;legend&gt;</c> element above the fields.
    /// Optional — omit for an anonymous grouping section with no visual label.
    /// </summary>
    [Parameter] public string Title { get; set; } = "";

    /// <summary>
    /// One-sentence guidance line rendered below the title in a muted font.
    /// Optional — use to clarify what information the user should enter in this section.
    /// </summary>
    [Parameter] public string Description { get; set; } = "";

    /// <summary>
    /// Controls how child fields are arranged inside the section content area.
    /// Accepted values:
    /// <list type="bullet">
    ///   <item><c>"stack"</c> — single column, vertical stack (default)</item>
    ///   <item><c>"grid-2"</c> — two equal columns (collapses to one column on mobile)</item>
    ///   <item><c>"grid-3"</c> — three equal columns (collapses to one column on mobile)</item>
    /// </list>
    /// </summary>
    [Parameter] public string Layout { get; set; } = "stack";

    /// <summary>
    /// When <c>true</c>, removes the card-style background and border so the section
    /// blends into its parent container. Useful for flat form designs or tight nesting.
    /// Default: <c>false</c>.
    /// </summary>
    [Parameter] public bool NoBorder { get; set; } = false;

    /// <summary>
    /// Reduces padding for use inside modals, drawers, or panels where vertical space is
    /// constrained. Default: <c>false</c>.
    /// </summary>
    [Parameter] public bool Compact { get; set; } = false;

    /// <summary>
    /// Applies a primary-colour border and light background tint to visually emphasise
    /// this section over its siblings (e.g. a required or critical field group).
    /// Default: <c>false</c>.
    /// </summary>
    [Parameter] public bool Highlighted { get; set; } = false;

    /// <summary>
    /// The form fields, inputs, and controls rendered inside the section content area.
    /// Laid out according to <see cref="Layout"/>.
    /// </summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Optional render fragment displayed in the section footer, separated by a top border.
    /// Use for section-level action buttons, "Save this section" links, or helper text.
    /// </summary>
    [Parameter] public RenderFragment? FooterContent { get; set; }

    protected override void OnInitialized()
    {
        SetDefaultValues();
    }

    protected override void OnParametersSet()
    {
        SetDefaultValues();
    }

    protected void SetDefaultValues()
    {
        _sectionClass = "";

        if (NoBorder) {
            _sectionClass += "no-border ";
        }
        if (Compact) {
            _sectionClass += "compact ";
        }
        if (Highlighted) {
            _sectionClass += "highlighted ";
        }

        _sectionClass = _sectionClass.Trim();
    }
}
