@*
    TablePagination — Foundation pagination control bar for paged data tables.

    Renders a Bootstrap-styled pagination nav alongside an item-count summary and an optional
    page-size selector. Designed to be paired with any data table that performs server-side or
    client-side paging by responding to the OnPageChanged and OnPageSizeChanged callbacks.

    Required parameters:
        TotalItems  — the full record count across all pages (drives total page calculation)
        CurrentPage — the currently active page number (1-indexed)
        PageSize    — the number of items displayed per page

    Optional parameters:
        PageSizeLabel   — label for the page-size dropdown (empty hides the dropdown)
        PageSizeOptions — available page-size choices (default: 5, 10, 25, 50, 100)
        PageWindow      — how many numbered page buttons to show at once (default 5)
        AriaLabel       — accessible label for the <nav> element
        OnPageChanged   — EventCallback<int> fired when the user changes the page
        OnPageSizeChanged — EventCallback<int> fired when the user picks a new page size

    Example:
        <TablePagination TotalItems="@_totalCount"
                         CurrentPage="@_page"
                         PageSize="@_pageSize"
                         OnPageChanged="LoadPageAsync"
                         OnPageSizeChanged="ChangePageSizeAsync" />
*@
@namespace FreeBlazorExtended.Components

<nav class="pagination-container" aria-label="@(String.IsNullOrWhiteSpace(AriaLabel) ? "Table pagination" : AriaLabel)">
    <div class="pagination-info">
        <span class="pagination-text">
            @if (_totalItems > 0) {
                <text>@_displayStart to @_displayEnd of @_totalItems items</text>
                @if (!String.IsNullOrWhiteSpace(PageSizeLabel)) {
                    <span class="ms-3">
                        <label for="pageSizeSelect" class="me-2">@PageSizeLabel:</label>
                        <select id="pageSizeSelect" class="form-select form-select-sm d-inline-block" style="width: auto;"
                            @onchange="PageSizeChanged"
                            aria-label="Items per page">
                            @foreach (int size in _pageSizeOptions) {
                                <option value="@size" selected="@(PageSize == size)">@size</option>
                            }
                        </select>
                    </span>
                }
            } else {
                <text>No items</text>
            }
        </span>
    </div>

    <ul class="pagination mb-0">
        <li class="page-item @(_currentPage == 1 ? "disabled" : "")">
            <button class="page-link" @onclick="FirstPage" disabled="@(_currentPage == 1)" aria-label="First page">
                <i class="fas fa-chevron-double-left" aria-hidden="true"></i>
            </button>
        </li>

        <li class="page-item @(_currentPage == 1 ? "disabled" : "")">
            <button class="page-link" @onclick="PreviousPage" disabled="@(_currentPage == 1)" aria-label="Previous page">
                <i class="fas fa-chevron-left" aria-hidden="true"></i>
            </button>
        </li>

        @if (_totalPages > 1) {
            @for (int i = _pageWindowStart; i <= _pageWindowEnd; i++) {
                int pageNum = i;
                <li class="page-item @(_currentPage == pageNum ? "active" : "")">
                    <button class="page-link" @onclick="@(() => GoToPage(pageNum))" aria-label="Go to page @pageNum" aria-current="@(_currentPage == pageNum ? "page" : null)">
                        @pageNum
                    </button>
                </li>
            }
        }

        <li class="page-item @(_currentPage == _totalPages ? "disabled" : "")">
            <button class="page-link" @onclick="NextPage" disabled="@(_currentPage == _totalPages)" aria-label="Next page">
                <i class="fas fa-chevron-right" aria-hidden="true"></i>
            </button>
        </li>

        <li class="page-item @(_currentPage == _totalPages ? "disabled" : "")">
            <button class="page-link" @onclick="LastPage" disabled="@(_currentPage == _totalPages)" aria-label="Last page">
                <i class="fas fa-chevron-double-right" aria-hidden="true"></i>
            </button>
        </li>
    </ul>
</nav>

<style>
    .pagination-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
        padding: 1rem 0;
        border-top: 1px solid var(--bs-border-color);
    }

    .pagination-info {
        display: flex;
        align-items: center;
    }

    .pagination-text {
        font-size: 0.95rem;
        color: var(--bs-body-color);
    }

    .pagination {
        margin-bottom: 0;
    }

    .page-link {
        color: var(--bs-link-color);
        border-color: var(--bs-border-color);
    }

    .page-link:hover {
        color: var(--bs-link-hover-color);
        background-color: var(--bs-light);
    }

    .page-item.active .page-link {
        background-color: var(--bs-primary);
        border-color: var(--bs-primary);
    }

    .page-item.disabled .page-link {
        color: var(--bs-secondary);
        cursor: not-allowed;
        opacity: 0.5;
    }

    @@media (max-width: 768px) {
        .pagination-container {
            flex-direction: column;
            align-items: stretch;
        }

        .pagination-info {
            justify-content: center;
        }

        .pagination {
            justify-content: center;
        }
    }
</style>

@code {
    private int _currentPage = 1;
    private int _totalPages = 1;
    private int _displayStart = 0;
    private int _displayEnd = 0;
    private int _pageWindowStart = 1;
    private int _pageWindowEnd = 1;
    private List<int> _pageSizeOptions = new() { 5, 10, 25, 50, 100 };

    /// <summary>
    /// Total record count across all pages.
    /// <para><b>Required.</b> Used to calculate the total number of pages and the
    /// "X to Y of Z" summary text.</para>
    /// </summary>
    [Parameter]
    public int TotalItems { get; set; } = 0;

    /// <summary>
    /// The currently active page number, 1-indexed.
    /// <para><b>Required.</b> Drives which page button is highlighted as active.
    /// Update this from your parent component in response to <see cref="OnPageChanged"/>.</para>
    /// </summary>
    [Parameter]
    public int CurrentPage { get; set; } = 1;

    /// <summary>
    /// Number of records displayed per page.
    /// <para><b>Required.</b> Used to derive total pages and the item-range summary.</para>
    /// </summary>
    [Parameter]
    public int PageSize { get; set; } = 10;

    /// <summary>
    /// Label displayed to the left of the page-size dropdown.
    /// Default: <c>"Items per page"</c>. Set to empty string to hide the dropdown entirely.
    /// </summary>
    [Parameter]
    public string PageSizeLabel { get; set; } = "Items per page";

    /// <summary>
    /// The set of available page-size options shown in the dropdown.
    /// Default: <c>5, 10, 25, 50, 100</c>. Override to match your data volume
    /// (e.g. omit large values for tables that rarely exceed 50 rows).
    /// </summary>
    [Parameter]
    public List<int> PageSizeOptions { get; set; } = new() { 5, 10, 25, 50, 100 };

    /// <summary>
    /// Maximum number of numbered page buttons shown at once in the pagination control.
    /// The window re-centres on the current page as the user navigates.
    /// Default: <c>5</c>.
    /// </summary>
    [Parameter]
    public int PageWindow { get; set; } = 5;

    /// <summary>
    /// Fired with the newly selected page number (1-indexed) when the user clicks a page
    /// button. Use to trigger a data reload: <code>OnPageChanged="LoadPageAsync"</code>.
    /// </summary>
    [Parameter]
    public EventCallback<int> OnPageChanged { get; set; }

    /// <summary>
    /// Fired with the newly selected page size when the user changes the dropdown.
    /// Typically resets to page 1 and reloads data:
    /// <code>OnPageSizeChanged="ChangePageSizeAsync"</code>.
    /// </summary>
    [Parameter]
    public EventCallback<int> OnPageSizeChanged { get; set; }

    /// <summary>
    /// Accessible label for the wrapping <c>&lt;nav&gt;</c> element read by screen readers.
    /// Default: <c>"Table pagination"</c>. Override when multiple paginations exist on one page.
    /// </summary>
    [Parameter]
    public string AriaLabel { get; set; } = "";

    private int _totalItems = 0;

    protected override void OnInitialized()
    {
        SetDefaultValues();
    }

    protected override void OnParametersSet()
    {
        SetDefaultValues();
    }

    protected void SetDefaultValues()
    {
        _totalItems = TotalItems;
        _currentPage = CurrentPage;
        _pageSizeOptions = PageSizeOptions ?? new() { 5, 10, 25, 50, 100 };

        _totalPages = (int)Math.Ceiling((double)_totalItems / PageSize);
        if (_totalPages < 1) _totalPages = 1;

        _displayStart = (_currentPage - 1) * PageSize + 1;
        _displayEnd = Math.Min(_currentPage * PageSize, _totalItems);

        CalculatePageWindow();
    }

    protected void CalculatePageWindow()
    {
        int windowHalf = PageWindow / 2;

        _pageWindowStart = Math.Max(1, _currentPage - windowHalf);
        _pageWindowEnd = Math.Min(_totalPages, _currentPage + windowHalf);

        if (_pageWindowStart + PageWindow - 1 < _totalPages) {
            _pageWindowEnd = _pageWindowStart + PageWindow - 1;
        }
        if (_pageWindowEnd - PageWindow + 1 > 1) {
            _pageWindowStart = _pageWindowEnd - PageWindow + 1;
        }
    }

    protected async Task GoToPage(int pageNumber)
    {
        if (pageNumber >= 1 && pageNumber <= _totalPages && pageNumber != _currentPage) {
            _currentPage = pageNumber;
            CalculatePageWindow();
            SetDefaultValues();
            await OnPageChanged.InvokeAsync(_currentPage);
        }
    }

    protected async Task NextPage()
    {
        await GoToPage(_currentPage + 1);
    }

    protected async Task PreviousPage()
    {
        await GoToPage(_currentPage - 1);
    }

    protected async Task FirstPage()
    {
        await GoToPage(1);
    }

    protected async Task LastPage()
    {
        await GoToPage(_totalPages);
    }

    protected async Task PageSizeChanged(ChangeEventArgs e)
    {
        int newSize = int.Parse(e.Value?.ToString() ?? PageSize.ToString());
        _currentPage = 1;
        await OnPageSizeChanged.InvokeAsync(newSize);
    }
}
