@*
    EmptyState — Foundation placeholder for lists, tables, and panels that contain no data yet.

    Use this component wherever a collection is empty or a search returns no results. It provides
    a consistent visual treatment across all surfaces and accepts optional call-to-action content
    to guide the user toward their next step.

    Required parameters: none — all have sensible defaults.

    Optional parameters:
        Title        — headline (default "No data")
        Description  — one-sentence explanation or guidance
        IconClass    — FontAwesome class for the decorative icon (default "fas fa-inbox")
        Compact      — reduces padding and minimum height for use inside cards or modals
        FullHeight   — expands to fill the full viewport height (for page-level empty states)
        ChildContent — render fragment for "Create your first item" buttons or links

    Example (table empty state):
        <EmptyState Title="No invoices yet"
                    Description="Create your first invoice to get started."
                    IconClass="fas fa-file-invoice">
            <button class="btn btn-primary" @onclick="CreateInvoice">New Invoice</button>
        </EmptyState>
*@
@namespace FreeBlazorExtended.Components

<div class="empty-state @_containerClass" role="status">
    <div class="empty-state-content">
        @if (!String.IsNullOrWhiteSpace(IconClass)) {
            <div class="empty-icon">
                <i class="@IconClass"></i>
            </div>
        }

        <h3 class="empty-title">@_title</h3>

        @if (!String.IsNullOrWhiteSpace(Description)) {
            <p class="empty-description">@Description</p>
        }

        @if (ChildContent != null) {
            <div class="empty-actions">
                @ChildContent
            </div>
        }
    </div>
</div>

<style>
    .empty-state {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 300px;
        padding: 2rem;
        background-color: var(--bs-light);
        border: 1px dashed var(--bs-border-color);
        border-radius: 0.375rem;
    }

    .empty-state.compact {
        min-height: 200px;
        padding: 1.5rem;
    }

    .empty-state.full-height {
        min-height: 100vh;
    }

    .empty-state-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        text-align: center;
        max-width: 400px;
    }

    .empty-icon {
        font-size: 3rem;
        color: var(--bs-secondary);
        opacity: 0.5;
    }

    .empty-title {
        margin: 0;
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--bs-body-color);
    }

    .empty-description {
        margin: 0;
        font-size: 0.95rem;
        color: var(--bs-secondary);
        line-height: 1.5;
    }

    .empty-actions {
        display: flex;
        gap: 0.75rem;
        margin-top: 1rem;
        flex-wrap: wrap;
        justify-content: center;
    }

    @@media (max-width: 768px) {
        .empty-state {
            min-height: 250px;
            padding: 1.5rem;
        }

        .empty-icon {
            font-size: 2.5rem;
        }

        .empty-title {
            font-size: 1.1rem;
        }

        .empty-description {
            font-size: 0.9rem;
        }
    }

    @@media (max-width: 576px) {
        .empty-state {
            min-height: 200px;
            padding: 1rem;
        }

        .empty-icon {
            font-size: 2rem;
        }

        .empty-title {
            font-size: 1rem;
        }

        .empty-actions {
            flex-direction: column;
        }

        .empty-actions button,
        .empty-actions a {
            width: 100%;
        }
    }
</style>

@code {
    protected string _title = "";
    protected string _containerClass = "";

    /// <summary>
    /// Primary headline displayed in the centre of the empty-state panel.
    /// Default: <c>"No data"</c>. Tailor to the specific context
    /// (e.g. <c>"No invoices yet"</c>, <c>"No results for this filter"</c>).
    /// </summary>
    [Parameter] public string Title { get; set; } = "No data";

    /// <summary>
    /// One-sentence explanation or guidance shown below the title in a muted font.
    /// Optional — use to tell the user why the list is empty and what they can do next.
    /// </summary>
    [Parameter] public string Description { get; set; } = "";

    /// <summary>
    /// FontAwesome class for the decorative icon displayed above the title.
    /// Default: <c>"fas fa-inbox"</c>.
    /// Choose an icon that matches the domain (e.g. <c>"fas fa-search"</c> for search results,
    /// <c>"fas fa-folder-open"</c> for file lists).
    /// Set to empty string to hide the icon entirely.
    /// </summary>
    [Parameter] public string IconClass { get; set; } = "fas fa-inbox";

    /// <summary>
    /// When <c>true</c>, reduces padding and minimum height for use inside cards,
    /// panels, or modal bodies where vertical space is constrained. Default: <c>false</c>.
    /// </summary>
    [Parameter] public bool Compact { get; set; } = false;

    /// <summary>
    /// When <c>true</c>, expands the container to fill the full viewport height.
    /// Use for page-level empty states (e.g., an empty dashboard with no widgets).
    /// Default: <c>false</c>.
    /// </summary>
    [Parameter] public bool FullHeight { get; set; } = false;

    /// <summary>
    /// Optional render fragment for call-to-action buttons or links displayed below the description.
    /// Example: a "Create your first item" button or a "Clear filters" link.
    /// </summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    protected override void OnInitialized()
    {
        SetDefaultValues();
    }

    protected override void OnParametersSet()
    {
        SetDefaultValues();
    }

    protected void SetDefaultValues()
    {
        _title = Title ?? "No data";

        _containerClass = "";
        if (Compact) {
            _containerClass += "compact ";
        }
        if (FullHeight) {
            _containerClass += "full-height ";
        }
        _containerClass = _containerClass.Trim();
    }
}
