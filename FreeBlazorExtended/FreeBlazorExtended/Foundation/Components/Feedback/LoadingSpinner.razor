@*
    LoadingSpinner — Foundation loading indicator with optional message, size control, and overlay mode.

    Drop this component wherever an async operation is in progress. Three display modes are available:
      • Default  — centred in its container with a 200 px minimum height
      • Overlay  — fixed full-screen darkened overlay (blocks user interaction during critical ops)
      • Inline   — no minimum height; sits inline with surrounding text or controls

    Required parameters: none — all parameters have safe defaults.

    Optional parameters:
        Size        — spinner diameter: "sm" | "md" (default) | "lg"
        Message     — text rendered below the spinner (e.g. "Loading report…")
        ShowOverlay — true to show a full-screen blocking overlay (use sparingly)
        Inline      — true to suppress the minimum height and display inline

    Example (default, page-scoped):
        <LoadingSpinner Message="Fetching data…" Size="lg" />

    Example (full-screen overlay during save):
        @if (_saving) { <LoadingSpinner ShowOverlay="true" Message="Saving…" /> }

    Example (inline, next to a label):
        Analysing <LoadingSpinner Inline="true" Size="sm" />
*@
@namespace FreeBlazorExtended.Components

<div class="loading-spinner @_spinnerClass" role="status" aria-live="polite" aria-label="@(!String.IsNullOrWhiteSpace(Message) ? Message : "Loading")">
    <div class="spinner-container">
        <div class="spinner @_sizeClass">
            <div class="spinner-border"></div>
        </div>

        @if (!String.IsNullOrWhiteSpace(Message)) {
            <p class="spinner-message">@Message</p>
        }
    </div>
</div>

<style>
    .loading-spinner {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 200px;
    }

    .loading-spinner.overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 9999;
        background-color: rgba(0, 0, 0, 0.5);
        min-height: 100vh;
    }

    .loading-spinner.inline {
        min-height: auto;
        display: inline-flex;
    }

    .spinner-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
    }

    .spinner {
        position: relative;
    }

    .spinner.sm {
        width: 20px;
        height: 20px;
    }

    .spinner.md {
        width: 40px;
        height: 40px;
    }

    .spinner.lg {
        width: 60px;
        height: 60px;
    }

    .spinner-border {
        width: 100%;
        height: 100%;
        border: 3px solid var(--bs-border-color);
        border-top-color: var(--bs-primary);
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    .spinner.sm .spinner-border {
        border-width: 2px;
    }

    .spinner.lg .spinner-border {
        border-width: 4px;
    }

    .spinner-message {
        margin: 0;
        font-size: 0.95rem;
        color: var(--bs-body-color);
        text-align: center;
        max-width: 300px;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    @@media (max-width: 768px) {
        .spinner.lg {
            width: 50px;
            height: 50px;
        }

        .spinner-message {
            font-size: 0.9rem;
        }
    }
</style>

@code {
    protected string _spinnerClass = "";
    protected string _sizeClass = "";

    /// <summary>
    /// Diameter of the spinner ring.
    /// Accepted values: <c>"sm"</c> (20 px), <c>"md"</c> (40 px, default), <c>"lg"</c> (60 px).
    /// Use <c>"sm"</c> inside buttons or inline text; use <c>"lg"</c> for full-panel placeholders.
    /// </summary>
    [Parameter] public string Size { get; set; } = "md";

    /// <summary>
    /// Explanatory text displayed below the spinner ring.
    /// Optional — omit for a minimal indicator with no label.
    /// Example: <c>"Fetching records…"</c>, <c>"Saving changes, please wait."</c>
    /// </summary>
    [Parameter] public string Message { get; set; } = "";

    /// <summary>
    /// When <c>true</c>, renders a fixed full-screen semi-transparent overlay that blocks
    /// all user interaction. Use during critical operations (file upload, payment processing)
    /// where accidental re-clicks must be prevented. Default: <c>false</c>.
    /// </summary>
    [Parameter] public bool ShowOverlay { get; set; } = false;

    /// <summary>
    /// When <c>true</c>, suppresses the default 200 px minimum height so the spinner
    /// sits inline with surrounding content (e.g., next to a label or inside a button).
    /// Default: <c>false</c>.
    /// </summary>
    [Parameter] public bool Inline { get; set; } = false;

    protected override void OnInitialized()
    {
        SetDefaultValues();
    }

    protected override void OnParametersSet()
    {
        SetDefaultValues();
    }

    protected void SetDefaultValues()
    {
        _sizeClass = (Size ?? "md").ToLower() switch
        {
            "sm" => "sm",
            "lg" => "lg",
            _ => "md"
        };

        _spinnerClass = "";
        if (ShowOverlay) {
            _spinnerClass += "overlay ";
        }
        if (Inline) {
            _spinnerClass += "inline ";
        }
        _spinnerClass = _spinnerClass.Trim();
    }
}
