@*
    Vertical Timeline — FedEx / UPS tracking page layout.
    Renders a column of events: state-indicator dot on the left, optional
    connector line between dots, content (title, timestamp, actor, details)
    on the right. Mobile-friendly — no horizontal space required.
*@

<div class="timeline-component @Class">
    @for (int i = 0; i < Events.Count; i++) {
        int idx = i;
        var evt = Events[i];
        bool isLast = i == Events.Count - 1;
        string stateClass = GetStateClass(evt.State);
        string textClass = GetTextClass(evt.State);
        string iconCss = !string.IsNullOrWhiteSpace(evt.Icon) ? evt.Icon! : DefaultIcon(evt.State);
        bool clickable = OnEventClick.HasDelegate;

        <div class="d-flex @(!isLast ? "mb-3" : "")">
            @* Left rail — dot + connector *@
            <div class="d-flex flex-column align-items-center me-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center @stateClass"
                     style="width:24px; height:24px; font-size:0.6rem; flex-shrink:0;">
                    <i class="@iconCss"></i>
                </div>
                @if (!isLast && ShowConnectorLine) {
                    <div class="flex-grow-1" style="width:2px; min-height:20px;">
                        <div class="h-100 @GetConnectorClass(evt.State)"></div>
                    </div>
                }
            </div>

            @* Right side — content *@
            <div class="flex-grow-1 pb-1 @(clickable ? "cursor-pointer" : "")"
                 role="@(clickable ? "button" : null)"
                 @onclick="@(() => HandleClick(evt))">
                <div class="small fw-semibold @textClass @(evt.State == TimelineEventState.Skipped ? "text-decoration-line-through" : "")">
                    @evt.Title
                </div>
                @if (ShowTimestamps || !string.IsNullOrWhiteSpace(evt.Actor)) {
                    <div class="small text-muted">
                        @if (ShowTimestamps) {
                            @(evt.Timestamp == default ? "Pending" : evt.Timestamp.ToString(TimestampFormat))
                        }
                        @if (!string.IsNullOrWhiteSpace(evt.Actor)) {
                            @if (ShowTimestamps && evt.Timestamp != default) {
                                <span> — </span>
                            }
                            <span>@evt.Actor</span>
                        }
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(evt.Description)) {
                    <div class="small mt-1">@evt.Description</div>
                }
                @if (!string.IsNullOrWhiteSpace(evt.DetailHtml)) {
                    <div class="small mt-1">@((MarkupString)evt.DetailHtml!)</div>
                }
            </div>
        </div>
    }
</div>

@code {
    /// <summary>The list of events to display, top-to-bottom.</summary>
    [Parameter] public List<TimelineEvent> Events { get; set; } = new();

    /// <summary>Show the timestamp under each event title.</summary>
    [Parameter] public bool ShowTimestamps { get; set; } = true;

    /// <summary>Show the vertical connector line between event dots.</summary>
    [Parameter] public bool ShowConnectorLine { get; set; } = true;

    /// <summary>DateTime format string for timestamps.</summary>
    [Parameter] public string TimestampFormat { get; set; } = "MMM d, h:mm tt";

    /// <summary>Fired when the user clicks an event row. If not wired, rows are not clickable.</summary>
    [Parameter] public EventCallback<TimelineEvent> OnEventClick { get; set; }

    /// <summary>Optional extra CSS class on the outer wrapper.</summary>
    [Parameter] public string Class { get; set; } = "";

    private async Task HandleClick(TimelineEvent evt)
    {
        if (OnEventClick.HasDelegate) {
            await OnEventClick.InvokeAsync(evt);
        }
    }

    private static string GetStateClass(TimelineEventState state) => state switch {
        TimelineEventState.Completed => "bg-success text-white",
        TimelineEventState.InProgress => "bg-primary text-white",
        TimelineEventState.Error => "bg-danger text-white",
        TimelineEventState.Skipped => "bg-secondary text-white",
        _ => "bg-light text-muted border",
    };

    private static string GetTextClass(TimelineEventState state) => state switch {
        TimelineEventState.InProgress => "text-primary",
        TimelineEventState.Error => "text-danger",
        TimelineEventState.Completed => "",
        TimelineEventState.Skipped => "text-muted",
        _ => "text-muted",
    };

    private static string GetConnectorClass(TimelineEventState state) => state switch {
        TimelineEventState.Completed => "bg-success",
        TimelineEventState.Error => "bg-danger",
        _ => "bg-secondary bg-opacity-25",
    };

    private static string DefaultIcon(TimelineEventState state) => state switch {
        TimelineEventState.Completed => "fa-solid fa-check",
        TimelineEventState.Error => "fa-solid fa-times",
        TimelineEventState.InProgress => "fa-solid fa-circle fa-xs",
        TimelineEventState.Skipped => "fa-solid fa-minus",
        _ => "fa-solid fa-circle fa-xs text-muted",
    };

    /// <summary>A single event in the timeline.</summary>
    public class TimelineEvent
    {
        public string Id { get; set; } = "";
        public string Title { get; set; } = "";
        public string? Description { get; set; }
        public DateTime Timestamp { get; set; }
        public TimelineEventState State { get; set; } = TimelineEventState.Completed;
        /// <summary>Optional FontAwesome class. If not set, a sensible default per state is used.</summary>
        public string? Icon { get; set; }
        /// <summary>Who/what triggered the event (e.g. "System", a user name).</summary>
        public string? Actor { get; set; }
        /// <summary>Optional richer detail block, rendered as MarkupString.</summary>
        public string? DetailHtml { get; set; }
    }

    /// <summary>State of a timeline event — drives color, icon, and styling.</summary>
    public enum TimelineEventState
    {
        Pending,
        InProgress,
        Completed,
        Error,
        Skipped,
    }
}
