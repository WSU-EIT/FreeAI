@page "/Settings/ManualChecks/{SiteId}"
@page "/{TenantCode}/Settings/ManualChecks/{SiteId}"
@implements IDisposable
@using Blazored.LocalStorage
@inject IJSRuntime jsRuntime
@inject HttpClient Http
@inject ILocalStorageService LocalStorage
@inject BlazorDataModel Model
@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title">
            <Language Tag="ManualCheckWizard" IncludeIcon="true" />
        </h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title">
                <Language Tag="ManualCheckWizard" IncludeIcon="true" />
                <StickyMenuIcon />
            </h1>
            <div class="btn-group mb-2" role="group">
                <a href="@(Helpers.BuildUrl("Settings/EditSite/" + SiteId))" class="btn btn-dark">
                    <Language Tag="Back" IncludeIcon="true" />
                </a>
            </div>
        </div>

        @* ── Site Name ── *@
        <div class="mb-3">
            <h5>@_site.Name</h5>
            <div class="text-muted">@_site.BaseUrl</div>
        </div>

        @* ── Progress Bar ── *@
        <div class="mb-3">
            <div class="d-flex justify-content-between mb-1">
                <span>@_checkedCount / @_allCriteria.Count <Language Tag="CriteriaChecked" /></span>
                <span>@(_currentIndex + 1) / @_allCriteria.Count</span>
            </div>
            <div class="progress" style="height: 24px;">
                <div class="progress-bar bg-success" role="progressbar"
                     style="width: @((_allCriteria.Count > 0 ? (_checkedCount * 100 / _allCriteria.Count) : 0))%"
                     aria-valuenow="@_checkedCount" aria-valuemin="0" aria-valuemax="@_allCriteria.Count">
                    @((_allCriteria.Count > 0 ? (_checkedCount * 100 / _allCriteria.Count) : 0))%
                </div>
            </div>
        </div>

        @if (_allCriteria.Any()) {
            var current = _allCriteria[_currentIndex];
            var check = GetOrCreateCheck(current.Number);

            @* ── Current Criterion Card ── *@
            <div class="card mb-3">
                <div class="card-header">
                    <strong>@current.Number</strong> &mdash; @current.Name
                    <span class="badge bg-secondary ms-2">@current.Level</span>
                    <span class="badge bg-dark ms-1">@current.Principle</span>
                </div>
                <div class="card-body">
                    <p class="mb-2"><strong><Language Tag="WhatToTest" />:</strong></p>
                    <p class="text-muted">@current.Description</p>

                    @* ── Status Radio Buttons ── *@
                    <div class="mb-3">
                        <label class="form-label"><Language Tag="ConformanceStatus" /></label>
                        <div class="form-check">
                            <input type="radio" class="form-check-input" id="status-pass"
                                   name="status" value="Pass" checked="@(check.Status == "Pass")"
                                   @onchange="@(() => SetStatus(check, "Pass"))" />
                            <label class="form-check-label" for="status-pass">
                                <span class="badge bg-success">Pass</span>
                            </label>
                        </div>
                        <div class="form-check">
                            <input type="radio" class="form-check-input" id="status-fail"
                                   name="status" value="Fail" checked="@(check.Status == "Fail")"
                                   @onchange="@(() => SetStatus(check, "Fail"))" />
                            <label class="form-check-label" for="status-fail">
                                <span class="badge bg-danger">Fail</span>
                            </label>
                        </div>
                        <div class="form-check">
                            <input type="radio" class="form-check-input" id="status-na"
                                   name="status" value="N/A" checked="@(check.Status == "N/A")"
                                   @onchange="@(() => SetStatus(check, "N/A"))" />
                            <label class="form-check-label" for="status-na">
                                <span class="badge bg-info">N/A</span>
                            </label>
                        </div>
                        <div class="form-check">
                            <input type="radio" class="form-check-input" id="status-nottested"
                                   name="status" value="Not Tested" checked="@(check.Status == "Not Tested" || String.IsNullOrWhiteSpace(check.Status))"
                                   @onchange="@(() => SetStatus(check, "Not Tested"))" />
                            <label class="form-check-label" for="status-nottested">
                                <span class="badge bg-secondary">Not Tested</span>
                            </label>
                        </div>
                    </div>

                    @* ── Notes ── *@
                    <div class="mb-3">
                        <label for="check-notes" class="form-label"><Language Tag="Notes" /></label>
                        <textarea id="check-notes" class="form-control" rows="3"
                                  @bind="check.Notes" @bind:event="oninput"></textarea>
                    </div>

                    @* ── Tested Info ── *@
                    @if (check.TestedAt.HasValue) {
                        <div class="text-muted small">
                            <Language Tag="TestedBy" />: @check.TestedBy &mdash; @check.TestedAt.Value.ToString("yyyy-MM-dd HH:mm")
                        </div>
                    }
                </div>
            </div>

            @* ── Navigation Buttons ── *@
            <div class="d-flex justify-content-between">
                <button type="button" class="btn btn-outline-dark" @onclick="Previous" disabled="@(_currentIndex == 0)">
                    <Language Tag="Previous" IncludeIcon="true" />
                </button>
                @if (_currentIndex < _allCriteria.Count - 1) {
                    <button type="button" class="btn btn-success" @onclick="NextAndSave">
                        <Language Tag="Next" IncludeIcon="true" />
                    </button>
                } else {
                    <button type="button" class="btn btn-success" @onclick="FinishAndSave">
                        <Language Tag="Save" IncludeIcon="true" />
                    </button>
                }
            </div>
        }
    }
}
@code {
    [Parameter] public string? SiteId { get; set; }
    [Parameter] public string? TenantCode { get; set; }

    private bool _loading = true;
    private bool _loadedData = false;
    private bool _validatedUrl = false;
    private string _pageName = "manualcheckwizard";

    private DataObjects.Site _site = new DataObjects.Site();
    private List<WcagCriterionDetail> _allCriteria = new();
    private List<DataObjects.ManualCheckResult> _manualChecks = new();
    private int _currentIndex = 0;
    private int _checkedCount = 0;

    public void Dispose()
    {
        Model.OnChange -= OnDataModelUpdated;
        Model.OnSignalRUpdate -= SignalRUpdate;
    }

    protected override void OnInitialized()
    {
        Model.OnChange += OnDataModelUpdated;
        Model.OnSignalRUpdate += SignalRUpdate;
        Model.View = _pageName;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) {
            Model.TenantCodeFromUrl = TenantCode;
        }

        if (Model.Loaded && Model.LoggedIn) {
            if (!Model.User.Admin) {
                Helpers.NavigateToRoot();
                return;
            }

            if (!_validatedUrl) {
                _validatedUrl = true;
                await Helpers.ValidateUrl(TenantCode);
            }

            if (!_loadedData) {
                _loadedData = true;
                await LoadData();
            }
        }
    }

    private void OnDataModelUpdated()
    {
        if (Model.View == _pageName) {
            StateHasChanged();
        }
    }

    private async Task LoadData()
    {
        _loading = true;

        _allCriteria = GetAllWcagCriteria();

        Guid siteGuid = Guid.Parse(SiteId!);

        var sites = await Helpers.GetOrPost<List<DataObjects.Site>>("api/Data/GetSites", new List<Guid> { siteGuid });
        if (sites != null && sites.Any()) {
            _site = sites.First();
        }

        var checks = await Helpers.GetOrPost<List<DataObjects.ManualCheckResult>>("api/Data/GetManualChecks", new { Ids = new List<Guid>(), SiteId = siteGuid });
        if (checks != null) {
            _manualChecks = checks;
        }

        UpdateCheckedCount();

        _loading = false;
        StateHasChanged();
    }

    private DataObjects.ManualCheckResult GetOrCreateCheck(string criterion)
    {
        var existing = _manualChecks.FirstOrDefault(x => x.WcagCriterion == criterion);
        if (existing != null) return existing;

        var newCheck = new DataObjects.ManualCheckResult {
            ManualCheckResultId = Guid.Empty,
            SiteId = Guid.Parse(SiteId!),
            WcagCriterion = criterion,
            Status = "Not Tested",
        };
        _manualChecks.Add(newCheck);
        return newCheck;
    }

    private void SetStatus(DataObjects.ManualCheckResult check, string status)
    {
        check.Status = status;
        if (status != "Not Tested") {
            check.TestedBy = Model.User.DisplayName;
            check.TestedAt = DateTime.UtcNow;
        }
        UpdateCheckedCount();
    }

    private void UpdateCheckedCount()
    {
        _checkedCount = _manualChecks.Count(x => !String.IsNullOrWhiteSpace(x.Status) && x.Status != "Not Tested");
    }

    private void Previous()
    {
        if (_currentIndex > 0) {
            _currentIndex--;
        }
    }

    private async Task NextAndSave()
    {
        await SaveCurrentCheck();
        if (_currentIndex < _allCriteria.Count - 1) {
            _currentIndex++;
        }
    }

    private async Task FinishAndSave()
    {
        await SaveCurrentCheck();
        Model.Message_Saved();
    }

    private async Task SaveCurrentCheck()
    {
        var current = _allCriteria[_currentIndex];
        var check = _manualChecks.FirstOrDefault(x => x.WcagCriterion == current.Number);

        if (check != null && !String.IsNullOrWhiteSpace(check.Status) && check.Status != "Not Tested") {
            check.SiteId = Guid.Parse(SiteId!);

            Model.Message_Saving();

            var saved = await Helpers.GetOrPost<List<DataObjects.ManualCheckResult>>("api/Data/SaveManualChecks", new List<DataObjects.ManualCheckResult> { check });

            Model.ClearMessages();

            if (saved != null && saved.Any()) {
                var result = saved.First();
                // Update local list with saved version
                int idx = _manualChecks.FindIndex(x => x.WcagCriterion == current.Number);
                if (idx >= 0) {
                    _manualChecks[idx] = result;
                }
            }

            UpdateCheckedCount();
            StateHasChanged();
        }
    }

    private void SignalRUpdate(DataObjects.SignalRUpdate update)
    {
        if (Model.View != _pageName || _site.SiteId == Guid.Empty) { return; }
        if (update.UpdateType == DataObjects.SignalRUpdateType.ScanComplete ||
            update.UpdateType == DataObjects.SignalRUpdateType.ScanFailed) {
            if (update.Object != null) {
                try {
                    var json = System.Text.Json.JsonSerializer.Serialize(update.Object);
                    var scanRun = System.Text.Json.JsonSerializer.Deserialize<DataObjects.ScanRun>(json,
                        new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                    if (scanRun != null && scanRun.SiteId == _site.SiteId) {
                        InvokeAsync(StateHasChanged);
                    }
                } catch { }
            }
        }
    }

    // ── WCAG 2.2 AA Criteria with descriptions ──

