            new() { Number = "2.2.1", Name = "Timing Adjustable", Principle = "Operable", Level = "A", Automatable = false },
            new() { Number = "2.2.2", Name = "Pause, Stop, Hide", Principle = "Operable", Level = "A", Automatable = false },
