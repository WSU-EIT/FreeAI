            new() { Number = "1.2.2", Name = "Captions (Prerecorded)", Principle = "Perceivable", Level = "A", Automatable = false },
            new() { Number = "1.2.3", Name = "Audio Description or Media Alternative", Principle = "Perceivable", Level = "A", Automatable = false },
            new() { Number = "1.2.5", Name = "Audio Description (Prerecorded)", Principle = "Perceivable", Level = "AA", Automatable = false },
            new() { Number = "1.3.1", Name = "Info and Relationships", Principle = "Perceivable", Level = "A", Automatable = true },
            new() { Number = "1.3.2", Name = "Meaningful Sequence", Principle = "Perceivable", Level = "A", Automatable = false },
            new() { Number = "1.3.3", Name = "Sensory Characteristics", Principle = "Perceivable", Level = "A", Automatable = false },
            new() { Number = "1.3.4", Name = "Orientation", Principle = "Perceivable", Level = "AA", Automatable = false },
            new() { Number = "1.3.5", Name = "Identify Input Purpose", Principle = "Perceivable", Level = "AA", Automatable = true },
            new() { Number = "1.4.1", Name = "Use of Color", Principle = "Perceivable", Level = "A", Automatable = false },
            new() { Number = "1.4.2", Name = "Audio Control", Principle = "Perceivable", Level = "A", Automatable = false },
            new() { Number = "1.4.3", Name = "Contrast (Minimum)", Principle = "Perceivable", Level = "AA", Automatable = true },
            new() { Number = "1.4.4", Name = "Resize Text", Principle = "Perceivable", Level = "AA", Automatable = false },
            new() { Number = "1.4.5", Name = "Images of Text", Principle = "Perceivable", Level = "AA", Automatable = false },
            new() { Number = "1.4.10", Name = "Reflow", Principle = "Perceivable", Level = "AA", Automatable = false },
            new() { Number = "1.4.11", Name = "Non-text Contrast", Principle = "Perceivable", Level = "AA", Automatable = true },
            new() { Number = "1.4.12", Name = "Text Spacing", Principle = "Perceivable", Level = "AA", Automatable = false },
            new() { Number = "1.4.13", Name = "Content on Hover or Focus", Principle = "Perceivable", Level = "AA", Automatable = false },
