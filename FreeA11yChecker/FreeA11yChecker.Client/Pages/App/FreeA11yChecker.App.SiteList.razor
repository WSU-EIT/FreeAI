    private string GetStatusBadge(DataObjects.Site site)
    {
        if (String.Equals(site.LastScanStatus, "Running", StringComparison.OrdinalIgnoreCase)
            || String.Equals(site.LastScanStatus, "Queued", StringComparison.OrdinalIgnoreCase)) {
            return "<span class=\"badge bg-info\"><span class=\"spinner-border spinner-border-sm me-1\" role=\"status\"></span>Scanning</span>";
        }
        if (!site.LastScanAt.HasValue) {
            return "<span class=\"badge bg-secondary\">Not Scanned</span>";
        }
        if (site.LastCriticalCount > 0) {
            return "<span class=\"badge bg-danger\">Critical</span>";
        }
        if (site.LastViolationCount > 0) {
            return "<span class=\"badge bg-warning text-dark\">Violations</span>";
        }
        return "<span class=\"badge bg-success\">Clean</span>";
    }

    private async Task ScanNow(Guid siteId)
    {
        // Optimistically show as Queued. The actual Scanning badge appears when the
        // background service broadcasts ScanStarted (handled in SignalRUpdate).
        _queuedIds.Add(siteId);
        StateHasChanged();

        var result = await Helpers.GetOrPost<DataObjects.ScanRun>("api/Data/TriggerScan", siteId);
        if (result != null && result.ActionResponse != null && !result.ActionResponse.Result) {
            _queuedIds.Remove(siteId);
            Model.ErrorMessages(result.ActionResponse.Messages);
            StateHasChanged();
        }
    }

    private void SignalRUpdate(DataObjects.SignalRUpdate update)
    {
        if (Model.View != _pageName) { return; }
        var jsonOptions = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };

        if (update.UpdateType == DataObjects.SignalRUpdateType.ScanQueued && update.Object != null) {
            try {
                var json = System.Text.Json.JsonSerializer.Serialize(update.Object);
                var scanRun = System.Text.Json.JsonSerializer.Deserialize<DataObjects.ScanRun>(json, jsonOptions);
                if (scanRun != null) {
                    _queuedIds.Add(scanRun.SiteId);
                    InvokeAsync(StateHasChanged);
                }
            } catch { }
        } else if (update.UpdateType == DataObjects.SignalRUpdateType.ScanStarted && update.Object != null) {
            // Background service picked up a queued scan and started running it.
            try {
                var json = System.Text.Json.JsonSerializer.Serialize(update.Object);
                var scanRun = System.Text.Json.JsonSerializer.Deserialize<DataObjects.ScanRun>(json, jsonOptions);
                if (scanRun != null) {
                    _queuedIds.Remove(scanRun.SiteId);
                    _scanningIds.Add(scanRun.SiteId);
                    InvokeAsync(StateHasChanged);
                }
            } catch { }
        } else if (update.UpdateType == DataObjects.SignalRUpdateType.ScanProgress && update.Object != null) {
            try {
                var json = System.Text.Json.JsonSerializer.Serialize(update.Object);
                var progress = System.Text.Json.JsonSerializer.Deserialize<DataObjects.ScanProgress>(json, jsonOptions);
                if (progress != null) {
                    _queuedIds.Remove(progress.SiteId);
                    _scanningIds.Add(progress.SiteId);
                    _scanProgress[progress.SiteId] = progress;
                    RequestThrottledRender();
                }
            } catch { }
        } else if (update.UpdateType == DataObjects.SignalRUpdateType.ScanComplete ||
                   update.UpdateType == DataObjects.SignalRUpdateType.ScanFailed) {
            if (update.Object == null) { return; }
            try {
                var json = System.Text.Json.JsonSerializer.Serialize(update.Object);
                var scanRun = System.Text.Json.JsonSerializer.Deserialize<DataObjects.ScanRun>(json, jsonOptions);
                if (scanRun != null) {
                    _scanningIds.Remove(scanRun.SiteId);
                    _queuedIds.Remove(scanRun.SiteId);
                    _scanProgress.Remove(scanRun.SiteId);

                    // Update just the affected site's summary from the event payload.
                    var site = _sites.FirstOrDefault(s => s.SiteId == scanRun.SiteId);
                    if (site != null) {
                        site.LastScanAt = scanRun.StartedAt;
                        site.LastScanStatus = scanRun.Status;
                        site.LastViolationCount = scanRun.TotalViolations;
                        site.LastCriticalCount = scanRun.CriticalCount;
                        site.LastScanRunId = scanRun.ScanRunId;
                    }

                    InvokeAsync(StateHasChanged);

                    // The scan likely discovered new same-host links that became disabled
                    // top-level Sites — and the page count for the scanned site may have grown.
                    // Reload the full Sites list so they appear in the tree without manual refresh.
                    InvokeAsync(async () => {
                        await RefreshSitesList();
                    });
                }
            } catch { }
        }
    }

    private void RequestThrottledRender()
    {
        if (_renderPending) return;
        _renderPending = true;
        _renderTimer?.Dispose();
        _renderTimer = new System.Threading.Timer(_ => {
            _renderPending = false;
            InvokeAsync(StateHasChanged);
        }, null, RenderThrottleMs, System.Threading.Timeout.Infinite);
    }

