    private void ToggleGroupNode(SiteTreeNode groupNode, bool enabled)
    {
        SetGroupEnabled(groupNode, enabled);
    }

    private void SetGroupEnabled(SiteTreeNode groupNode, bool enabled)
    {
        // Enable/disable the group node's own site (if it has one).
        if (groupNode.Site != null) {
            SetSiteEnabled(groupNode.Site, enabled);
        }
        // Cascade to all descendants.
        SetDescendantsEnabled(groupNode, enabled);
    }

    private int CountEnabledDescendants(SiteTreeNode node)
    {
        int count = 0;
        foreach (var child in node.Children) {
            if (child.Site != null && child.Site.Enabled) count++;
            count += CountEnabledDescendants(child);
        }
        return count;
    }

