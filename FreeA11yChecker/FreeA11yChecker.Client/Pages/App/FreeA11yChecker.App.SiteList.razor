    /// <summary>
    /// Finds a Site that this site is a "same-host child of" — i.e. another site whose
    /// BaseUrl is a strict URL prefix of this one (e.g. flex.em.wsu.edu is a parent of
    /// flex.em.wsu.edu/Touchpoints). Returns null if no such parent exists. Used to
    /// decide whether to show the "Convert to Page" button on a Site row.
    /// </summary>
    private DataObjects.Site? FindSameHostParentSite(DataObjects.Site site)
    {
        try {
            Uri thisUri = new Uri(site.BaseUrl.TrimEnd('/'));
            string thisNormalized = thisUri.AbsoluteUri.TrimEnd('/').ToLowerInvariant();

            // Walk all sites to find the LONGEST prefix match — that's the closest parent.
            DataObjects.Site? best = null;
            int bestLen = -1;
            foreach (var candidate in _sites) {
                if (candidate.SiteId == site.SiteId) continue;
                if (candidate.Deleted) continue;
                string candNorm = candidate.BaseUrl.TrimEnd('/').ToLowerInvariant();
                if (candNorm.Length >= thisNormalized.Length) continue;
                // Must match host AND be a prefix terminating on a path boundary (or origin).
                if (!thisNormalized.StartsWith(candNorm, StringComparison.OrdinalIgnoreCase)) continue;
                char nextChar = thisNormalized[candNorm.Length];
                if (nextChar != '/' && nextChar != '?' && nextChar != '#') continue;
                if (candNorm.Length > bestLen) {
                    best = candidate;
                    bestLen = candNorm.Length;
                }
            }
            return best;
        } catch {
            return null;
        }
    }

    /// <summary>
    /// Promotes a SitePage into its own Site. Used when a discovered "page" is actually
    /// a virtual sub-app that warrants its own auth/schedule/scan policy. The new Site
    /// inherits the page's full URL (parent.BaseUrl + page.Path) as its BaseUrl. The
    /// original SitePage is deleted from the parent.
    /// </summary>
    private async Task PromotePageToSite(DataObjects.Site parentSite, DataObjects.SitePage page)
    {
        try {
            string fullUrl = (parentSite.BaseUrl.TrimEnd('/') + (page.Path.StartsWith("/") ? page.Path : "/" + page.Path)).TrimEnd('/');
            string newName = string.IsNullOrWhiteSpace(page.Title)
                ? parentSite.Name + " / " + page.Path.Trim('/').Split('/').LastOrDefault()
                : page.Title;

            var newSite = new DataObjects.Site {
                SiteId = Guid.Empty,
                TenantId = parentSite.TenantId,
                Name = newName,
                BaseUrl = fullUrl,
                Enabled = page.Enabled,
                PublicVisible = true,
                MaxConcurrency = parentSite.MaxConcurrency > 0 ? parentSite.MaxConcurrency : 5,
            };

            var saved = await Helpers.GetOrPost<List<DataObjects.Site>>("api/Data/SaveSites",
                new List<DataObjects.Site> { newSite });
            if (saved == null || !saved.Any()) {
                Model.UnknownError();
                return;
            }

            // Delete the original page on the parent.
            await Helpers.GetOrPost<DataObjects.BooleanResponse>("api/Data/DeleteSitePages",
                new List<Guid> { page.SitePageId });

            // Refresh local state.
            if (_sitePages.ContainsKey(parentSite.SiteId)) {
                _sitePages[parentSite.SiteId].RemoveAll(p => p.SitePageId == page.SitePageId);
                _sitePageCounts[parentSite.SiteId] = _sitePages[parentSite.SiteId].Count;
            }
            await LoadData();
        } catch (Exception ex) {
            await Helpers.ConsoleLog("PromotePageToSite failed: " + ex.Message);
            Model.UnknownError();
        }
    }

    /// <summary>
    /// Confirmation wrapper around ConvertSiteToPage. Shows what will happen
    /// (delete this site's scan history, move N pages over) before doing it.
    /// </summary>
    private async Task ConfirmConvertSiteToPage(DataObjects.Site site, DataObjects.Site parentSite)
    {
        int pageCount = _sitePageCounts.ContainsKey(site.SiteId) ? _sitePageCounts[site.SiteId] : 0;
        string msg = $"Convert '{site.Name}' into a page of '{parentSite.Name}'?\n\n"
            + $"• A new page will be created on '{parentSite.Name}' for this site's URL.\n"
            + (pageCount > 0 ? $"• {pageCount} pages currently on '{site.Name}' will be moved to '{parentSite.Name}' (with paths re-rooted).\n" : "")
            + $"• '{site.Name}' will be deleted, including any scan history.\n\n"
            + $"Continue?";
        bool confirmed = await jsRuntime.InvokeAsync<bool>("confirm", msg);
        if (!confirmed) return;
        await ConvertSiteToPage(site, parentSite);
    }

    private async Task ConvertSiteToPage(DataObjects.Site site, DataObjects.Site parentSite)
    {
        try {
            // The path-suffix that distinguishes this site from its parent.
            string parentBase = parentSite.BaseUrl.TrimEnd('/');
            string thisBase = site.BaseUrl.TrimEnd('/');
            string suffix = "/";
            if (thisBase.StartsWith(parentBase, StringComparison.OrdinalIgnoreCase)
                && thisBase.Length > parentBase.Length) {
                suffix = thisBase.Substring(parentBase.Length);
                if (!suffix.StartsWith("/")) suffix = "/" + suffix;
            }

            // Load this site's existing pages so we can move them too.
            if (!_sitePages.ContainsKey(site.SiteId)) {
                var pages = await Helpers.GetOrPost<List<DataObjects.SitePage>>(
                    "api/Data/GetSitePages", new { Ids = new List<Guid>(), SiteId = site.SiteId });
                _sitePages[site.SiteId] = pages ?? new();
            }

            // Load parent's existing pages for de-dup.
            var parentPages = await Helpers.GetOrPost<List<DataObjects.SitePage>>(
                "api/Data/GetSitePages", new { Ids = new List<Guid>(), SiteId = parentSite.SiteId }) ?? new();
            HashSet<string> existingPaths = new HashSet<string>(parentPages.Select(p => p.Path), StringComparer.OrdinalIgnoreCase);

            int sortOrder = parentPages.Count;
            List<DataObjects.SitePage> toAdd = new List<DataObjects.SitePage>();

            // Add the site's BaseUrl itself as a page (e.g. "/Touchpoints").
            if (!existingPaths.Contains(suffix)) {
                sortOrder++;
                toAdd.Add(new DataObjects.SitePage {
                    SitePageId = Guid.Empty,
                    SiteId = parentSite.SiteId,
                    Path = suffix,
                    Title = site.Name,
                    Enabled = site.Enabled,
                    RequiresAuth = false,
                    SortOrder = sortOrder,
                });
                existingPaths.Add(suffix);
            }

            // Add each of the converted site's pages with paths re-rooted under the parent.
            foreach (var p in _sitePages[site.SiteId]) {
                string childPath = p.Path.StartsWith("/") ? p.Path : "/" + p.Path;
                string newPath = (suffix.TrimEnd('/') + childPath);
                if (string.IsNullOrEmpty(newPath)) newPath = "/";
                if (existingPaths.Contains(newPath)) continue;
                sortOrder++;
                toAdd.Add(new DataObjects.SitePage {
                    SitePageId = Guid.Empty,
                    SiteId = parentSite.SiteId,
                    Path = newPath,
                    Title = p.Title,
                    Enabled = p.Enabled,
                    RequiresAuth = p.RequiresAuth,
                    SortOrder = sortOrder,
                });
                existingPaths.Add(newPath);
            }

            if (toAdd.Any()) {
                await Helpers.GetOrPost<List<DataObjects.SitePage>>("api/Data/SaveSitePages", toAdd);
            }

            // Delete the original site (cascades scan history per existing FKs).
            await Helpers.GetOrPost<DataObjects.BooleanResponse>("api/Data/DeleteSites",
                new List<Guid> { site.SiteId });

            await LoadData();
        } catch (Exception ex) {
            await Helpers.ConsoleLog("ConvertSiteToPage failed: " + ex.Message);
            Model.UnknownError();
        }
    }

    private void ToggleSite(DataObjects.Site site, bool enabled)
    {
        // Per-row toggle affects only this single site. Cascading to descendants
        // is done via the "Enable All Under" / "Disable All Under" toolbar buttons.
        SetSiteEnabled(site, enabled);
    }

    private void SetSiteEnabled(DataObjects.Site site, bool enabled)
    {
        site.Enabled = enabled;
        if (_sitePages.ContainsKey(site.SiteId)) {
            foreach (var page in _sitePages[site.SiteId]) {
                page.Enabled = enabled;
            }
        }
    }

    private void SetDescendantsEnabled(SiteTreeNode node, bool enabled)
    {
        foreach (var child in node.Children) {
            if (child.Site != null) {
                SetSiteEnabled(child.Site, enabled);
            }
            SetDescendantsEnabled(child, enabled);
        }
    }

    private void EnableSubSites(SiteTreeNode node)
    {
        SetDescendantsEnabled(node, true);
    }

    private void DisableSubSites(SiteTreeNode node)
    {
        SetDescendantsEnabled(node, false);
    }

    private string GetSiteCheckState(DataObjects.Site site)
    {
        if (!_sitePages.ContainsKey(site.SiteId)) {
            return site.Enabled ? "checked" : "unchecked";
        }
        var pages = _sitePages[site.SiteId];
        if (!pages.Any()) return site.Enabled ? "checked" : "unchecked";
        bool allOn = site.Enabled && pages.All(p => p.Enabled);
        bool allOff = !site.Enabled && pages.All(p => !p.Enabled);
        if (allOn) return "checked";
        if (allOff) return "unchecked";
        return "indeterminate";
    }

    private async Task BulkSave()
    {
        _bulkSaving = true;
        StateHasChanged();

        await Helpers.GetOrPost<List<DataObjects.Site>>("api/Data/SaveSites", _sites);

        var allPages = _sitePages.Values.SelectMany(p => p).ToList();
        if (allPages.Any()) {
            await Helpers.GetOrPost<List<DataObjects.SitePage>>("api/Data/SaveSitePages", allPages);
        }

        _bulkSaving = false;
        _bulkMode = false;
        await LoadData();
    }

    private void BulkEnableAll()
    {
        foreach (var site in _sites) {
            site.Enabled = true;
            if (_sitePages.ContainsKey(site.SiteId)) {
                foreach (var page in _sitePages[site.SiteId]) page.Enabled = true;
            }
        }
    }

    private void BulkDisableAll()
    {
        foreach (var site in _sites) {
            site.Enabled = false;
            if (_sitePages.ContainsKey(site.SiteId)) {
                foreach (var page in _sitePages[site.SiteId]) page.Enabled = false;
            }
        }
    }

    private void BulkInvertAll()
    {
        foreach (var site in _sites) {
            site.Enabled = !site.Enabled;
            if (_sitePages.ContainsKey(site.SiteId)) {
                foreach (var page in _sitePages[site.SiteId]) page.Enabled = site.Enabled;
            }
