@page "/Settings/Sites"
@page "/{TenantCode}/Settings/Sites"
@implements IDisposable
@using Blazored.LocalStorage
@using Humanizer
@inject IJSRuntime jsRuntime
@inject HttpClient Http
@inject ILocalStorageService LocalStorage
@inject BlazorDataModel Model
@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title">
            <Language Tag="Sites" IncludeIcon="true" />
        </h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title">
                <Language Tag="Sites" IncludeIcon="true" />
                <StickyMenuIcon />
            </h1>
            <div class="btn-group mb-2" role="group">
                <a href="@(Helpers.BuildUrl("Settings/EditSite/new"))" role="button" class="btn btn-success">
                    <Language Tag="AddNewSite" IncludeIcon="true" />
                </a>
                <button type="button" class="btn btn-outline-primary" @onclick="ScanAllEnabled" disabled="@_bulkScanning">
                    @if (_bulkScanning) {<span class="spinner-border spinner-border-sm me-1"></span>}
                    <i class="fas fa-play me-1"></i>Queue All Enabled
                </button>
                <a href="@(Helpers.BuildUrl("Compliance/Scorecard"))" role="button" class="btn btn-outline-info" title="Cross-site triage views: scorecard, URL search, domain tree, rule hotlist">
                    <i class="fas fa-bullseye me-1"></i>Triage Across Sites
                </a>
                <a href="@(Helpers.BuildUrl("Settings/Suppressions"))" role="button" class="btn btn-outline-warning" title="Manage rules suppressed for known third-party issues">
                    <i class="fas fa-shield-alt me-1"></i>Suppressions
                </a>
            </div>
        </div>

        <FreeA11yChecker_App_AboutSection Title="About Sites">
            <p><Language Tag="SitesAboutText" /></p>
        </FreeA11yChecker_App_AboutSection>

        <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
            <label for="siteSearchInput" class="visually-hidden">Search sites</label>
            <input type="text" id="siteSearchInput" class="form-control" placeholder="Search sites..."
                   style="max-width:400px;"
                   @bind="_searchText" @bind:event="oninput" />
            <fieldset class="btn-group btn-group-sm m-0 p-0 border-0" style="display:inline-flex;">
                <legend class="visually-hidden">Filter by enabled status</legend>
                <input type="radio" class="btn-check" name="enabledFilter" id="enabledFilterAll" autocomplete="off"
                       checked="@(_enabledFilter == "all")" @onchange="@(() => SetEnabledFilter("all"))" />
                <label class="btn btn-outline-secondary" for="enabledFilterAll">
                    All <span class="badge bg-secondary ms-1">@_sites.Count</span>
                </label>

                <input type="radio" class="btn-check" name="enabledFilter" id="enabledFilterEnabled" autocomplete="off"
                       checked="@(_enabledFilter == "enabled")" @onchange="@(() => SetEnabledFilter("enabled"))" />
                <label class="btn btn-outline-success" for="enabledFilterEnabled">
                    Enabled only <span class="badge bg-success ms-1">@_sites.Count(s => s.Enabled)</span>
                </label>

                <input type="radio" class="btn-check" name="enabledFilter" id="enabledFilterDisabled" autocomplete="off"
                       checked="@(_enabledFilter == "disabled")" @onchange="@(() => SetEnabledFilter("disabled"))" />
                <label class="btn btn-outline-secondary" for="enabledFilterDisabled">
                    Disabled only <span class="badge bg-dark ms-1">@_sites.Count(s => !s.Enabled)</span>
                </label>
            </fieldset>
        </div>

        @* ── Bulk Edit Toolbar ── *@
        <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
            <button class="btn btn-sm @(_bulkMode ? "btn-primary" : "btn-outline-primary")"
                    @onclick="ToggleBulkMode">
                <i class="fas fa-check-double me-1"></i>Bulk Edit
            </button>
            @if (_bulkMode) {
                int enabledCount = _sites.Count(s => s.Enabled);
                int totalCount = _sites.Count;
                <span class="badge bg-dark fs-6">@enabledCount / @totalCount enabled</span>

                @* ── Selection group ── *@
                <div class="btn-group">
                    <button class="btn btn-sm btn-outline-success" @onclick="BulkEnableAll" title="Enable every site">
                        <i class="fas fa-check-square me-1"></i>Enable All
                    </button>
                    <button class="btn btn-sm btn-outline-danger" @onclick="BulkDisableAll" title="Disable every site">
                        <i class="far fa-square me-1"></i>Disable All
                    </button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="BulkInvertAll" title="Flip enabled/disabled on every site">
                        <i class="fas fa-exchange-alt me-1"></i>Invert
                    </button>
                </div>

                @* ── Smart select dropdown ── *@
                <div class="dropdown">
                    <button class="btn btn-sm btn-outline-info dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="fas fa-magic me-1"></i>Smart Select
                    </button>
                    <ul class="dropdown-menu">
                        <li><h6 class="dropdown-header">Enable by status</h6></li>
                        <li><button class="dropdown-item" @onclick="() => SelectByStatus_Enable(true)"><i class="fas fa-exclamation-triangle text-danger me-2"></i>Enable sites with critical issues</button></li>
                        <li><button class="dropdown-item" @onclick="() => SelectByStatus_EnableViolations()"><i class="fas fa-exclamation-circle text-warning me-2"></i>Enable sites with any violations</button></li>
                        <li><button class="dropdown-item" @onclick="() => SelectByStatus_EnableClean()"><i class="fas fa-check-circle text-success me-2"></i>Enable only clean sites</button></li>
                        <li><button class="dropdown-item" @onclick="() => SelectByStatus_EnableNotScanned()"><i class="fas fa-question-circle text-secondary me-2"></i>Enable unscanned sites</button></li>
                        <li><hr class="dropdown-divider" /></li>
                        <li><h6 class="dropdown-header">Disable by status</h6></li>
                        <li><button class="dropdown-item" @onclick="() => SelectByStatus_DisableClean()"><i class="fas fa-check-circle text-success me-2"></i>Disable clean sites (focus on problems)</button></li>
                        <li><button class="dropdown-item" @onclick="() => SelectByStatus_DisableNotScanned()"><i class="fas fa-question-circle text-secondary me-2"></i>Disable unscanned sites</button></li>
                    </ul>
                </div>

                @* ── Actions ── *@
                <div class="btn-group">
                    <button class="btn btn-sm btn-outline-primary" @onclick="ScanSelected" disabled="@(_bulkScanning || enabledCount == 0)"
                            title="Queue scans for all enabled sites">
                        @if (_bulkScanning) {<span class="spinner-border spinner-border-sm me-1"></span>}
                        <i class="fas fa-play me-1"></i>Queue Enabled (@enabledCount)
                    </button>
                    <button class="btn btn-sm btn-success" @onclick="BulkSave" disabled="@_bulkSaving"
                            title="Save all enable/disable changes to the server">
                        @if (_bulkSaving) {<span class="spinner-border spinner-border-sm me-1"></span>}
                        <i class="fas fa-save me-1"></i>Save Changes
                    </button>
                </div>

                <button class="btn btn-sm btn-outline-dark" @onclick="ToggleBulkMode">
                    <i class="fas fa-times me-1"></i>Exit Bulk
                </button>
            }
        </div>

        var treeRoots = BuildSiteTree();
        if (treeRoots.Any()) {
            <div class="d-flex align-items-center mb-2">
                <button type="button" class="btn btn-sm btn-outline-secondary me-2" @onclick="ExpandAllNodes" @onclick:preventDefault="true">
                    <i class="fas fa-expand-alt me-1"></i>Expand All
                </button>
                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="CollapseAllNodes" @onclick:preventDefault="true">
                    <i class="fas fa-compress-alt me-1"></i>Collapse All
                </button>
            </div>
            <div class="list-group">
                @foreach (var node in treeRoots) {
                    RenderTreeNode(node, 0);
                }
            </div>
        } else {
            <Language Tag="NoItemsToShow" />
        }
    }
}

@{ void RenderTreeNode(SiteTreeNode node, int depth) {
    int indent = depth * 24;
    if (node.Site != null) {
        var site = node.Site;
        string itemClass = "list-group-item d-flex align-items-center";
        if (site.Deleted) {
            itemClass += " list-group-item-secondary";
        } else if (!site.Enabled) {
            itemClass += " list-group-item-light text-muted";
        }
        bool hasChildren = node.Children.Any();
        bool isExpanded = _expandedTreeNodes.Contains(node.Key);
        <div class="@itemClass" style="padding-left: @(12 + indent)px;">
            @if (hasChildren) {
                <button type="button" class="btn btn-sm btn-link p-0 me-2 text-dark" style="width:24px; height:24px; z-index:2;"
                        @onclick="() => ToggleTreeNode(node.Key)" @onclick:preventDefault="true" @onclick:stopPropagation="true"
                        aria-label="@(isExpanded ? "Collapse " + site.Name : "Expand " + site.Name)"
                        aria-expanded="@isExpanded.ToString().ToLower()">
                    <i class="fas @(isExpanded ? "fa-chevron-down" : "fa-chevron-right")" aria-hidden="true"></i>
                </button>
            } else {
                <span style="width:20px; display:inline-block;" class="me-2" aria-hidden="true"></span>
            }
            @if (_bulkMode) {
                <div class="me-2" @onclick:stopPropagation="true">
                    @{var checkState = GetSiteCheckState(site);}
                    <input type="checkbox" class="form-check-input" id="site-check-@site.SiteId"
                           aria-label="@($"Select {site.Name}")"
                           checked="@(checkState != "unchecked")"
                           @onchange="@(e => ToggleSite(site, (bool)e.Value!))" />
                </div>
            }
            <a href="@(Helpers.BuildUrl("Settings/SiteRuns/" + site.SiteId))" class="flex-grow-1 text-decoration-none text-reset">
                <div class="d-flex align-items-center mb-1">
                    <strong class="me-2">@site.Name</strong>
                    @if (!site.Enabled) {
                        <span class="badge bg-secondary me-1">Disabled</span>
                    }
                    @if (_scanningIds.Contains(site.SiteId)) {
                        <span class="badge bg-info me-1">
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            @if (_scanProgress.ContainsKey(site.SiteId)) {
                                var p = _scanProgress[site.SiteId];
                                @($"Scanning {p.CurrentPage}/{p.TotalPages}")
                            } else {
                                @("Scanning")
                            }
                        </span>
                    } else if (_queuedIds.Contains(site.SiteId)) {
                        <span class="badge bg-warning text-dark me-1" title="Waiting in queue">
                            <i class="fas fa-clock me-1"></i>Queued
                        </span>
                    } else {
                        @((MarkupString)GetStatusBadge(site))
                    }
                </div>
                <div class="d-flex align-items-center text-muted small">
                    <span class="me-3">@site.BaseUrl</span>
                    @if (site.LastScanAt.HasValue) {
                        <span class="me-3"><i class="fas fa-clock me-1"></i>@site.LastScanAt.Value.Humanize()</span>
                    }
                    @if (site.LastViolationCount > 0 || site.LastCriticalCount > 0) {
                        <span class="me-2">
                            <span class="badge bg-dark badge-sm">@site.LastViolationCount violations</span>
                            @if (site.LastCriticalCount > 0) {
                                <span class="badge bg-danger badge-sm ms-1">@site.LastCriticalCount critical</span>
                            }
                        </span>
                    }
                    @{
                        int pageCount = _sitePageCounts.ContainsKey(site.SiteId) ? _sitePageCounts[site.SiteId] : 0;
                        bool pagesExpanded = _expandedSites.Contains(site.SiteId);
                    }
                    <button type="button" class="btn btn-sm btn-link p-0 me-2 text-decoration-none"
                            @onclick="() => ToggleExpand(site.SiteId)"
                            @onclick:stopPropagation="true" @onclick:preventDefault="true"
                            aria-label="@(pagesExpanded ? "Collapse pages list" : "Expand pages list")"
                            aria-expanded="@pagesExpanded.ToString().ToLower()"
                            title="@(pagesExpanded ? "Hide pages" : "Show pages")">
                        <i class="fas @(pagesExpanded ? "fa-chevron-down" : "fa-chevron-right") me-1" aria-hidden="true"></i>
                        <i class="fas fa-file-alt me-1" aria-hidden="true"></i>@pageCount pages
                    </button>
                    @if (hasChildren) {
                        <span class="badge bg-light text-dark border me-2">@CountDescendants(node) sub-sites</span>
                    }
                </div>
            </a>
            <div class="d-flex align-items-center ms-2" @onclick:stopPropagation="true">
                @if (site.Enabled && !_scanningIds.Contains(site.SiteId) && !_queuedIds.Contains(site.SiteId)) {
                    <button type="button" class="btn btn-sm btn-outline-primary me-1"
                            title="@($"Run scan: {site.Name}")"
                            aria-label="@($"Run scan: {site.Name}")"
                            @onclick="@(() => ScanNow(site.SiteId))">
                        <i class="fas fa-play" aria-hidden="true"></i>
                    </button>
                }
                @{ var parentSiteForDemote = FindSameHostParentSite(site); }
                @if (parentSiteForDemote != null) {
                    <button type="button" class="btn btn-sm btn-outline-warning me-1"
                            @onclick="() => ConfirmConvertSiteToPage(site, parentSiteForDemote)"
                            title="@($"Convert this Site into a page (and its sub-pages) of its parent: {parentSiteForDemote.Name}. Deletes this site's scan history.")"
                            aria-label="@($"Convert site {site.Name} to a page of {parentSiteForDemote.Name}")">
                        <i class="fas fa-arrow-down" aria-hidden="true"></i>
                    </button>
                }
                <a href="@(Helpers.BuildUrl("Settings/EditSite/" + site.SiteId))" class="btn btn-sm btn-outline-secondary me-1"
                   title="@($"Settings: {site.Name}")"
                   aria-label="@($"Settings: {site.Name}")">
                    <i class="fas fa-cog" aria-hidden="true"></i>
                </a>
                <DeleteConfirmation OnConfirmed="@(() => DeleteSite(site.SiteId))"
                                    CancelText="@Helpers.ConfirmButtonTextCancel"
                                    DeleteText="@Helpers.ConfirmButtonTextDelete"
                                    ConfirmDeleteText="@Helpers.ConfirmButtonTextConfirmDelete" />
            </div>
        </div>
        @if (_bulkMode && hasChildren && isExpanded) {
            int childTotal = CountDescendants(node);
            int childEnabled = CountEnabledDescendants(node);
            <div class="list-group-item py-1 d-flex align-items-center" style="padding-left: @(36 + indent)px; background-color: #f8f9fa;">
                <small class="text-muted me-2">@childEnabled / @childTotal sub-sites enabled</small>
                <div class="btn-group" @onclick:stopPropagation="true">
                    <button type="button" class="btn btn-sm btn-outline-success py-0 px-2" style="font-size:0.75rem;"
                            @onclick="() => EnableSubSites(node)" @onclick:preventDefault="true" @onclick:stopPropagation="true"
                            title="Enable all sub-sites under @site.Name">
                        <i class="fas fa-check-square me-1"></i>Enable All Under
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-danger py-0 px-2" style="font-size:0.75rem;"
                            @onclick="() => DisableSubSites(node)" @onclick:preventDefault="true" @onclick:stopPropagation="true"
                            title="Disable all sub-sites under @site.Name">
                        <i class="far fa-square me-1"></i>Disable All Under
                    </button>
                </div>
            </div>
        }
        @if (_expandedSites.Contains(site.SiteId)) {
            @if (_sitePages.ContainsKey(site.SiteId)) {
                @if (!_sitePages[site.SiteId].Any()) {
                    <div class="list-group-item py-2 text-muted small" style="padding-left: @(48 + indent)px;">
                        <i class="fas fa-info-circle me-1"></i>No pages configured.
                        <a href="@(Helpers.BuildUrl("Settings/EditSite/" + site.SiteId))" class="ms-2">
                            Add pages →
                        </a>
                    </div>
                } else if (_bulkMode) {
                    @* ── Bulk-edit mode: simple checkbox list for fast multi-select ── *@
                    <div class="list-group-item py-2" style="padding-left: @(48 + indent)px; background-color: #f8f9fa;">
                        @foreach (var page in _sitePages[site.SiteId].OrderBy(p => p.SortOrder)) {
                            string pageCheckId = "page-check-" + page.SitePageId;
                            <div @key="page.SitePageId" class="form-check mb-1">
                                <input type="checkbox" class="form-check-input" id="@pageCheckId" @bind="page.Enabled" />
                                <label class="form-check-label" for="@pageCheckId">
                                    @(page.Path)
                                    @if (!String.IsNullOrEmpty(page.Title)) {
                                        <small class="text-muted">(@(page.Title))</small>
                                    }
                                </label>
                            </div>
                        }
                    </div>
                } else {
                    @* ── Normal mode: full row per page, matching site row style ── *@
                    @foreach (var page in _sitePages[site.SiteId].OrderBy(p => p.SortOrder)) {
                        string pageRowClass = "list-group-item d-flex align-items-center";
                        if (!page.Enabled) {
                            pageRowClass += " list-group-item-light text-muted";
                        }
                        <div @key="page.SitePageId" class="@pageRowClass" style="padding-left: @(48 + indent)px;">
                            <span style="width:20px; display:inline-block;" class="me-2" aria-hidden="true"></span>
                            <i class="fas fa-file-alt me-2 text-muted" aria-hidden="true"></i>
                            <div class="flex-grow-1">
                                <div class="d-flex align-items-center">
                                    <code class="me-2">@(page.Path)</code>
                                    @if (!page.Enabled) {
                                        <span class="badge bg-secondary me-1">Disabled</span>
                                    }
                                    @if (page.RequiresAuth) {
                                        <span class="badge bg-info text-dark me-1" title="Requires authentication">
                                            <i class="fas fa-lock me-1"></i>Auth
                                        </span>
                                    }
                                </div>
                                @if (!String.IsNullOrEmpty(page.Title)) {
                                    <div class="text-muted small">@(page.Title)</div>
                                }
                            </div>
                            <button type="button" class="btn btn-sm btn-outline-info me-1"
                                    @onclick="() => PromotePageToSite(site, page)"
                                    title="@($"Promote {page.Path} into its own Site (e.g. for a virtual sub-app that needs its own auth/schedule)")"
                                    aria-label="@($"Promote page {page.Path} to a new Site")">
                                <i class="fas fa-arrow-up" aria-hidden="true"></i>
                            </button>
                            <a href="@(Helpers.BuildUrl("Settings/EditSite/" + site.SiteId))"
                               class="btn btn-sm btn-outline-secondary me-1"
                               title="@($"Edit page: {page.Path}")"
                               aria-label="@($"Edit page: {page.Path}")">
                                <i class="fas fa-cog" aria-hidden="true"></i>
                            </a>
                        </div>
                    }
                }
            } else {
                <div class="list-group-item py-2 text-muted small" style="padding-left: @(48 + indent)px;">
                    <span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span>Loading pages...
                </div>
            }
        }
        @if (isExpanded) {
            foreach (var child in node.Children.OrderBy(c => c.Label)) {
                RenderTreeNode(child, depth + 1);
            }
        }
    } else {
        @* Group node (no site, just a label) — render as a collapsible header *@
        bool isExpanded = _expandedTreeNodes.Contains(node.Key);
        int groupTotal = CountDescendants(node);
        int groupEnabled = CountEnabledDescendants(node);
        <div class="list-group-item list-group-item-light d-flex align-items-center fw-bold"
             style="padding-left: @(12 + indent)px;">
            <button class="btn btn-sm btn-link p-0 me-2 text-dark" style="width:20px;"
                    @onclick="() => ToggleTreeNode(node.Key)" @onclick:preventDefault="true"
                    aria-label="@(isExpanded ? "Collapse " + node.Label : "Expand " + node.Label)"
                    aria-expanded="@isExpanded.ToString().ToLower()">
                <i class="fas @(isExpanded ? "fa-chevron-down" : "fa-chevron-right")" aria-hidden="true"></i>
            </button>
            @if (_bulkMode) {
                <div class="me-2" @onclick:stopPropagation="true">
                    @{ bool groupAllEnabled = groupEnabled == groupTotal && groupTotal > 0;
                       bool groupNoneEnabled = groupEnabled == 0; }
                    <input type="checkbox" class="form-check-input" id="group-check-@node.Key"
                           aria-label="@($"Select all sites under {node.Label}")"
                           checked="@groupAllEnabled"
                           @onchange="@(e => ToggleGroupNode(node, (bool)e.Value!))" />
                </div>
            }
            <i class="fas fa-globe me-2 text-muted" role="button" @onclick="() => ToggleTreeNode(node.Key)"></i>
            <span role="button" @onclick="() => ToggleTreeNode(node.Key)" class="me-auto">@node.Label</span>
            <span class="badge bg-light text-dark border ms-2">@groupTotal</span>
            @if (_bulkMode) {
                <span class="badge @(groupEnabled == groupTotal ? "bg-success" : groupEnabled > 0 ? "bg-warning text-dark" : "bg-secondary") ms-1"
                      style="font-size:0.7rem;">@groupEnabled enabled</span>
                <div class="btn-group ms-2" @onclick:stopPropagation="true">
                    <button type="button" class="btn btn-sm btn-outline-success py-0 px-2" style="font-size:0.7rem;"
                            @onclick="() => SetGroupEnabled(node, true)" @onclick:preventDefault="true"
                            title="Enable all @groupTotal sites under @node.Label">
                        <i class="fas fa-check-square me-1"></i>All
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-danger py-0 px-2" style="font-size:0.7rem;"
                            @onclick="() => SetGroupEnabled(node, false)" @onclick:preventDefault="true"
                            title="Disable all @groupTotal sites under @node.Label">
                        <i class="far fa-square me-1"></i>None
                    </button>
                </div>
            }
        </div>
        @if (isExpanded) {
            foreach (var child in node.Children.OrderBy(c => c.Label)) {
                RenderTreeNode(child, depth + 1);
            }
        }
    }
} }

@code {
    [Parameter] public string? TenantCode { get; set; }

    private bool _loadedData = false;
    private bool _loading = true;
    private bool _validatedUrl = false;
    private string _pageName = "sites";
    private string _searchText = "";
    private string _enabledFilter = "all"; // "all" | "enabled" | "disabled"

    private void SetEnabledFilter(string value)
    {
        _enabledFilter = value;
        StateHasChanged();
    }
    private List<DataObjects.Site> _sites = new();
    private HashSet<Guid> _scanningIds = new();
    private HashSet<Guid> _queuedIds = new();
    private Dictionary<Guid, DataObjects.ScanProgress> _scanProgress = new();
    private Dictionary<Guid, int> _sitePageCounts = new();
    private Dictionary<Guid, List<DataObjects.SitePage>> _sitePages = new();
    private HashSet<Guid> _expandedSites = new();
    private HashSet<string> _expandedTreeNodes = new();
    private List<SiteTreeNode> _lastTreeRoots = new();
    private Dictionary<Guid, SiteTreeNode> _nodeMap = new();
    private bool _treeInitialized = false;
    private bool _bulkMode = false;
    private bool _bulkSaving = false;
    private bool _bulkScanning = false;
    private System.Threading.Timer? _renderTimer;
    private bool _renderPending = false;
    private const int RenderThrottleMs = 300;

    public void Dispose()
    {
        _renderTimer?.Dispose();
        Model.OnChange -= OnDataModelUpdated;
        Model.OnSignalRUpdate -= SignalRUpdate;
    }

    protected override void OnInitialized()
    {
        Model.OnChange += OnDataModelUpdated;
        Model.OnSignalRUpdate += SignalRUpdate;
        Model.View = _pageName;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) {
            Model.TenantCodeFromUrl = TenantCode;
        }

        if (Model.Loaded && Model.LoggedIn) {
            if (!Model.User.Admin) {
                Helpers.NavigateToRoot();
                return;
            }

            if (!_validatedUrl) {
                _validatedUrl = true;
                await Helpers.ValidateUrl(TenantCode);
            }

            if (!_loadedData) {
                _loadedData = true;
                await LoadData();
            }
        }

        if (_bulkMode) {
            foreach (var site in _sites) {
                var state = GetSiteCheckState(site);
                if (state == "indeterminate") {
                    // Cannot assign to an optional-chaining expression in JS — that's a
                    // SyntaxError ("Invalid left-hand side in assignment") which Blazor
                    // bubbles up as an unhandled component-render exception. Use the same
                    // var-then-guard pattern as SetGroupIndeterminateState below.
                    await jsRuntime.InvokeVoidAsync("eval",
                        $"var el = document.getElementById('site-check-{site.SiteId}'); if (el) el.indeterminate = true;");
                }
            }
            // Set indeterminate on group (domain) checkboxes.
            foreach (var root in _lastTreeRoots) {
                await SetGroupIndeterminateState(root);
            }
        }
    }

