    private async Task LoadData()
    {
        _loading = true;
        _sitePages.Clear();
        _expandedSites.Clear();
        var result = await Helpers.GetOrPost<List<DataObjects.Site>>("api/Data/GetSites", new List<Guid>());
        if (result != null) {
            _sites = result;

            // Load page counts for each site.
            _sitePageCounts.Clear();
            foreach (var site in _sites) {
                var pages = await Helpers.GetOrPost<List<DataObjects.SitePage>>("api/Data/GetSitePages",
                    new { Ids = new List<Guid>(), SiteId = site.SiteId });
                _sitePageCounts[site.SiteId] = pages?.Count ?? 0;
            }
        }
        _loading = false;
        StateHasChanged();
    }

    /// <summary>
    /// Reloads the Sites list and page counts in-place without toggling the page-level
    /// loading spinner. Used after ScanComplete so newly-discovered disabled sub-sites
    /// appear in the tree alongside the scan-completion summary update.
    /// </summary>
    private async Task RefreshSitesList()
    {
        try {
            var result = await Helpers.GetOrPost<List<DataObjects.Site>>("api/Data/GetSites", new List<Guid>());
            if (result == null) return;
            _sites = result;
            _sitePageCounts.Clear();
            foreach (var site in _sites) {
                var pages = await Helpers.GetOrPost<List<DataObjects.SitePage>>("api/Data/GetSitePages",
                    new { Ids = new List<Guid>(), SiteId = site.SiteId });
                _sitePageCounts[site.SiteId] = pages?.Count ?? 0;
            }
            _treeInitialized = false; // Force tree rebuild so new Sites appear in the right group.
            StateHasChanged();
        } catch { /* best-effort refresh — failures will self-correct on next manual reload */ }
    }

    private List<DataObjects.Site> GetFilteredSites()
    {
        IEnumerable<DataObjects.Site> seq = _sites;
        if (_enabledFilter == "enabled") {
            seq = seq.Where(x => x.Enabled);
        } else if (_enabledFilter == "disabled") {
            seq = seq.Where(x => !x.Enabled);
        }
        if (!String.IsNullOrWhiteSpace(_searchText)) {
            string search = _searchText.Trim().ToLower();
            seq = seq.Where(x => x.Name.ToLower().Contains(search) || x.BaseUrl.ToLower().Contains(search));
        }
        return seq.OrderBy(x => x.Name).ToList();
    }

