    private async Task ScanAllEnabled()
    {
        _bulkScanning = true;
        StateHasChanged();
        var toScan = _sites.Where(s => s.Enabled
            && !_scanningIds.Contains(s.SiteId)
            && !_queuedIds.Contains(s.SiteId)).ToList();
        // Optimistically mark all as queued so the UI shows the queued state immediately.
        // The background service flips them to Scanning one-at-a-time via ScanStarted SignalR.
        foreach (var site in toScan) {
            _queuedIds.Add(site.SiteId);
        }
        StateHasChanged();
        // Fire all queue requests concurrently — each creates a "Queued" ScanRun.
        // The background service processes them one at a time.
        var tasks = toScan.Select(site => QueueScan(site.SiteId)).ToList();
        await Task.WhenAll(tasks);
        _bulkScanning = false;
        StateHasChanged();
    }

    private async Task ScanSelected()
    {
        _bulkScanning = true;
        StateHasChanged();
        var toScan = _sites.Where(s => s.Enabled
            && !_scanningIds.Contains(s.SiteId)
            && !_queuedIds.Contains(s.SiteId)).ToList();
        foreach (var site in toScan) {
            _queuedIds.Add(site.SiteId);
        }
        StateHasChanged();
        var tasks = toScan.Select(site => QueueScan(site.SiteId)).ToList();
        await Task.WhenAll(tasks);
        _bulkScanning = false;
        StateHasChanged();
    }

    private async Task QueueScan(Guid siteId)
    {
        var result = await Helpers.GetOrPost<DataObjects.ScanRun>("api/Data/TriggerScan", siteId);
        if (result != null && result.ActionResponse != null && !result.ActionResponse.Result) {
            // Queue request rejected (e.g. already running) — clear the optimistic queued mark.
            _queuedIds.Remove(siteId);
        }
    }

    // ================================================================
    // Tree model and building logic
    // ================================================================

    private class SiteTreeNode
    {
        public string Key { get; set; } = "";
        public string Label { get; set; } = "";
        public DataObjects.Site? Site { get; set; }
        public List<SiteTreeNode> Children { get; set; } = new();
    }

    private void ToggleTreeNode(string key)
    {
        if (!_expandedTreeNodes.Remove(key)) {
            _expandedTreeNodes.Add(key);
        }
    }

    private void ExpandAllNodes()
    {
        CollectAllNodeKeys(_lastTreeRoots, _expandedTreeNodes);
    }

    private void CollapseAllNodes()
    {
        _expandedTreeNodes.Clear();
    }

    private void CollectAllNodeKeys(List<SiteTreeNode> nodes, HashSet<string> keys)
    {
        foreach (var node in nodes) {
            if (node.Children.Any()) {
                keys.Add(node.Key);
                CollectAllNodeKeys(node.Children, keys);
            }
        }
    }

    private int CountDescendants(SiteTreeNode node)
    {
        int count = 0;
        foreach (var child in node.Children) {
            if (child.Site != null) count++;
            count += CountDescendants(child);
        }
        return count;
    }

    private async Task SetGroupIndeterminateState(SiteTreeNode node)
    {
        if (node.Site == null && node.Children.Any()) {
            int total = CountDescendants(node);
            int enabled = CountEnabledDescendants(node);
            if (enabled > 0 && enabled < total) {
                await jsRuntime.InvokeVoidAsync("eval",
                    $"var el = document.getElementById('group-check-{node.Key}'); if (el) el.indeterminate = true;");
            }
        }
        foreach (var child in node.Children) {
            await SetGroupIndeterminateState(child);
        }
    }

    /// <summary>
    /// Builds a hierarchical tree from the flat list of sites.
    /// Sites are grouped by domain, then nested by URL path segments.
    /// A site B is a child of site A if B's URL starts with A's URL.
    /// Subdomain sites (e.g. edit.em.wsu.edu) are children of their parent domain site (em.wsu.edu).
    /// </summary>
    private List<SiteTreeNode> BuildSiteTree()
    {
        var filtered = GetFilteredSites();
        if (!filtered.Any()) return new();

        // Parse each site URL into parts for comparison.
        var parsed = filtered.Select(s => {
            try {
                var uri = new Uri(s.BaseUrl.TrimEnd('/'));
                return new { Site = s, Uri = uri, NormalizedUrl = uri.ToString().TrimEnd('/').ToLowerInvariant() };
            } catch {
                return new { Site = s, Uri = (Uri?)null, NormalizedUrl = s.BaseUrl.ToLowerInvariant() };
            }
        }).Where(x => x.Uri != null).ToList();

        // Sort by URL length so parents come before children.
        parsed.Sort((a, b) => a.NormalizedUrl!.Length.CompareTo(b.NormalizedUrl!.Length));

        // Build a flat list of tree nodes, assigning each to its closest parent.
        var nodeMap = new Dictionary<string, SiteTreeNode>(); // key = normalized URL
        var roots = new List<SiteTreeNode>();

        foreach (var item in parsed) {
            var node = new SiteTreeNode {
                Key = "site-" + item.Site.SiteId,
                Label = item.Site.Name,
                Site = item.Site,
            };

            // Find the closest ancestor.
            SiteTreeNode? parent = null;

            // 1. Check for path-based parent: same host, shorter path.
            string host = item.Uri!.Host.ToLowerInvariant();
            string path = item.Uri.AbsolutePath.TrimEnd('/');
            if (!String.IsNullOrEmpty(path) && path != "/") {
                // Walk up path segments to find a parent.
                string[] segments = path.Split('/', StringSplitOptions.RemoveEmptyEntries);
                for (int i = segments.Length - 1; i >= 0; i--) {
                    string parentPath = i == 0 ? "" : "/" + String.Join("/", segments.Take(i));
                    string parentUrl = (item.Uri.Scheme + "://" + host + parentPath).ToLowerInvariant();
                    if (nodeMap.TryGetValue(parentUrl, out var pathParent)) {
                        parent = pathParent;
                        break;
                    }
                }
            }

            // 2. If no path parent, check for subdomain parent.
            if (parent == null) {
                string[] hostParts = host.Split('.');
                for (int i = 1; i < hostParts.Length - 1; i++) {
                    string parentHost = String.Join(".", hostParts.Skip(i));
                    // Try with scheme.
                    string parentUrl = (item.Uri.Scheme + "://" + parentHost).ToLowerInvariant();
                    if (nodeMap.TryGetValue(parentUrl, out var subParent)) {
                        parent = subParent;
                        break;
                    }
                    // Also try https specifically.
                    parentUrl = ("https://" + parentHost).ToLowerInvariant();
                    if (nodeMap.TryGetValue(parentUrl, out subParent)) {
                        parent = subParent;
                        break;
                    }
                }
            }

            if (parent != null) {
                parent.Children.Add(node);
            } else {
                roots.Add(node);
            }

            nodeMap[item.NormalizedUrl!] = node;
        }

        // Post-process: group orphan root nodes by base domain.
        // When multiple sites share a base domain (e.g. app.smartsheet.com,
        // community.smartsheet.com) but the bare domain isn't a site, create
        // a virtual grouping node so they appear nested together.
        roots = GroupRootsByBaseDomain(roots);

        // Build SiteId → node lookup for cascading.
        _nodeMap.Clear();
        BuildNodeMap(roots);

        // Auto-expand root nodes on first build only.
        if (!_treeInitialized) {
            _treeInitialized = true;
            foreach (var root in roots) {
                if (root.Children.Any()) {
                    _expandedTreeNodes.Add(root.Key);
                }
            }
        }

        _lastTreeRoots = roots.OrderBy(r => r.Label).ToList();
        return _lastTreeRoots;
    }

    private void BuildNodeMap(List<SiteTreeNode> nodes)
    {
        foreach (var node in nodes) {
            if (node.Site != null) {
                _nodeMap[node.Site.SiteId] = node;
            }
            BuildNodeMap(node.Children);
        }
    }

    /// <summary>
    /// Groups root-level tree nodes by their registrable base domain.
    /// If multiple roots share the same base domain, a virtual parent node is
    /// created so they appear nested (e.g. app.smartsheet.com and
    /// community.smartsheet.com → grouped under "smartsheet.com").
    /// </summary>
    private List<SiteTreeNode> GroupRootsByBaseDomain(List<SiteTreeNode> roots)
    {
        var grouped = new Dictionary<string, List<SiteTreeNode>>(StringComparer.OrdinalIgnoreCase);
        var ungrouped = new List<SiteTreeNode>();

        foreach (var root in roots) {
            string baseDomain = "";
            if (root.Site != null) {
                try {
                    var host = new Uri(root.Site.BaseUrl).Host.ToLowerInvariant();
                    if (host.StartsWith("www.")) host = host.Substring(4);
                    baseDomain = GetBaseDomain(host);
                } catch { }
            }

            if (string.IsNullOrEmpty(baseDomain)) {
                ungrouped.Add(root);
            } else {
                if (!grouped.ContainsKey(baseDomain))
                    grouped[baseDomain] = new List<SiteTreeNode>();
                grouped[baseDomain].Add(root);
            }
        }

        var result = new List<SiteTreeNode>(ungrouped);
        foreach (var kvp in grouped) {
            if (kvp.Value.Count == 1) {
                // Only one site for this domain — keep at root level.
                result.Add(kvp.Value[0]);
            } else {
                // Multiple sites share the domain — create a virtual parent.
                var virtualNode = new SiteTreeNode {
                    Key = "domain-" + kvp.Key,
                    Label = kvp.Key,
                    Site = null,
                    Children = kvp.Value.OrderBy(x => x.Label).ToList()
                };
                result.Add(virtualNode);
            }
        }

        return result;
    }

    /// <summary>
    /// Extracts the registrable base domain from a hostname.
    /// e.g. "app.smartsheet.com" → "smartsheet.com",
    ///      "em.wsu.edu" → "wsu.edu",
    ///      "foo.co.uk" → "foo.co.uk".
    /// </summary>
    private string GetBaseDomain(string host)
    {
        var parts = host.Split('.');
        if (parts.Length <= 2) return host;

        // Common multi-part TLD suffixes where the registrable domain
        // includes one extra label (e.g. example.co.uk).
        var multiPartTlds = new HashSet<string>(StringComparer.OrdinalIgnoreCase) {
            "co.uk", "org.uk", "ac.uk", "gov.uk",
            "com.au", "org.au", "edu.au",
            "co.nz", "org.nz",
            "co.jp", "or.jp", "ne.jp",
            "com.br", "org.br",
            "co.in", "org.in",
            "co.za",
        };

        string lastTwo = parts[^2] + "." + parts[^1];
        if (multiPartTlds.Contains(lastTwo) && parts.Length > 3) {
            return parts[^3] + "." + lastTwo;
        }

        return parts[^2] + "." + parts[^1];
    }
}
