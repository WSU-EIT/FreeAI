@page "/Settings/EditSite/{SiteId}"
@page "/{TenantCode}/Settings/EditSite/{SiteId}"
@implements IDisposable
@using Blazored.LocalStorage
@inject IJSRuntime jsRuntime
@inject HttpClient Http
@inject ILocalStorageService LocalStorage
@inject BlazorDataModel Model
@inject Radzen.DialogService DialogService
@if (Model.Loaded && Model.View == _pageName) {
    @if (_loading) {
        <h1 class="page-title">
            <Language Tag="@_title" IncludeIcon="true" />
        </h1>
        <LoadingMessage />
    } else {
        <div class="@Model.StickyMenuClass">
            <h1 class="page-title">
                <Language Tag="@_title" IncludeIcon="true" />
                <StickyMenuIcon />
            </h1>
            <div class="btn-group mb-2" role="group">
                <a href="@(Helpers.BuildUrl("Settings/Sites"))" class="btn btn-dark">
                    <Language Tag="Back" IncludeIcon="true" />
                </a>
                <button type="button" class="btn btn-success" @onclick="Save">
                    <Language Tag="Save" IncludeIcon="true" />
                </button>
                @if (!_isNew && _site.Enabled) {
                    @if (_scanning) {
                        <button type="button" class="btn btn-outline-info" disabled>
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            @if (_editScanProgress != null) {
                                @($"Scanning {_editScanProgress.CurrentPage}/{_editScanProgress.TotalPages}")
                            } else {
                                @("Scan Queued...")
                            }
                        </button>
                    } else {
                        <button type="button" class="btn btn-outline-primary" @onclick="ScanNow">
                            <i class="fas fa-play"></i> Scan Now
                        </button>
                    }
                }
                @if (!_isNew) {
                    <DeleteConfirmation OnConfirmed="Delete"
                                        CancelText="@Helpers.ConfirmButtonTextCancel"
                                        DeleteText="@Helpers.ConfirmButtonTextDelete"
                                        ConfirmDeleteText="@Helpers.ConfirmButtonTextConfirmDelete" />
                }
            </div>
        </div>

        @* ── Tab Navigation ── *@
        <ul class="nav nav-tabs mb-3">
            <li class="nav-item">
                <button type="button" class="nav-link @(_activeTab == "details" ? "active" : "")"
                        @onclick="@(() => _activeTab = "details")">
                    <Language Tag="Details" />
                </button>
            </li>
            @if (!_isNew) {
                <li class="nav-item">
                    <button type="button" class="nav-link @(_activeTab == "pages" ? "active" : "")"
                            @onclick="@(() => _activeTab = "pages")">
                        <Language Tag="Pages" /> <span class="badge bg-secondary">@_pages.Count</span>
                    </button>
                </li>
                <li class="nav-item">
                    <button type="button" class="nav-link @(_activeTab == "credentials" ? "active" : "")"
                            @onclick="@(() => _activeTab = "credentials")">
                        <Language Tag="Credentials" /> <span class="badge bg-secondary">@_credentials.Count</span>
                    </button>
                </li>
                <li class="nav-item">
                    <button type="button" class="nav-link @(_activeTab == "manualchecks" ? "active" : "")"
                            @onclick="@(() => _activeTab = "manualchecks")">
                        <Language Tag="ManualChecks" /> <span class="badge bg-secondary">@_manualChecks.Count</span>
                    </button>
                </li>
            }
        </ul>

        @* ── Details Tab ── *@
        @if (_activeTab == "details") {
            <RequiredIndicator />

            <div class="mb-2 form-check form-switch">
                <input type="checkbox" role="switch" class="form-check-input" id="edit-site-Enabled" @bind="_site.Enabled" />
                <label for="edit-site-Enabled" class="form-check-label"><Language Tag="Enabled" /></label>
            </div>

            <div class="mb-2 form-check form-switch">
                <input type="checkbox" role="switch" class="form-check-input" id="edit-site-PublicVisible" @bind="_site.PublicVisible" />
                <label for="edit-site-PublicVisible" class="form-check-label"><Language Tag="PublicVisible" /></label>
            </div>

            <div class="mb-2 form-check form-switch">
                <input type="checkbox" role="switch" class="form-check-input" id="edit-site-IsFreeCRMApp" @bind="_site.IsFreeCRMApp" />
                <label for="edit-site-IsFreeCRMApp" class="form-check-label"><Language Tag="IsFreeCRMApp" /></label>
            </div>

            <div class="mb-2">
                <label for="edit-site-Name">
                    <Language Tag="Name" Required="true" />
                </label>
                <input type="text" id="edit-site-Name" @bind="_site.Name" @bind:event="oninput"
                       class="@Helpers.MissingValue(_site.Name, "form-control")" />
            </div>

            <div class="mb-2">
                <label for="edit-site-BaseUrl">
                    <Language Tag="BaseUrl" Required="true" />
                </label>
                <input type="text" id="edit-site-BaseUrl" @bind="_site.BaseUrl" @bind:event="oninput"
                       class="@Helpers.MissingValue(_site.BaseUrl, "form-control")"
                       placeholder="https://example.com" />
            </div>

            <div class="mb-2">
                <label for="edit-site-ScanScheduleCron">
                    <Language Tag="ScanScheduleCron" />
                </label>
                <input type="text" id="edit-site-ScanScheduleCron" @bind="_site.ScanScheduleCron" @bind:event="oninput"
                       class="form-control" placeholder="0 2 * * 0" />
                <small class="text-muted"><Language Tag="CronFormatHelp" /></small>
            </div>

            <div class="mb-2">
                <label for="edit-site-MaxConcurrency">
                    <Language Tag="MaxConcurrency" />
                </label>
                <input type="number" id="edit-site-MaxConcurrency" @bind="_site.MaxConcurrency"
                       class="form-control" min="1" max="20" />
            </div>

            @if (!_isNew && _site.LastScanAt.HasValue) {
                <div class="mb-2">
                    <label><Language Tag="LastScan" /></label>
                    <div class="form-control-plaintext">
                        @_site.LastScanAt.Value.ToString("yyyy-MM-dd HH:mm") &mdash;
                        @((MarkupString)GetStatusBadge(_site))
                        (@_site.LastViolationCount <Language Tag="Violations" />)
                    </div>
                </div>
            }
        }

        @* ── Pages Tab ── *@
        @if (_activeTab == "pages") {
            <div class="mb-2">
                <button type="button" class="btn btn-success btn-sm" @onclick="AddPage">
                    <Language Tag="AddPage" IncludeIcon="true" />
                </button>
                <button type="button" class="btn btn-outline-info btn-sm" @onclick="DiscoverLinks" disabled="@_discoverLoading">
                    @if (_discoverLoading) {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    } else {
                        <i class="fas fa-search"></i>
                    }
                    Explore
                </button>
                <button type="button" class="btn btn-primary btn-sm" @onclick="SavePages">
                    <Language Tag="SaveAll" IncludeIcon="true" />
                </button>
            </div>

            @if (_showDiscoverPanel && _discoverResult != null) {
                <div class="card mb-3">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <strong>Discovered Links</strong>
                        <button type="button" class="btn-close" @onclick="@(() => _showDiscoverPanel = false)"></button>
                    </div>
                    <div class="card-body">
                        @if (!String.IsNullOrEmpty(_discoverResult.ErrorMessage)) {
                            <div class="alert alert-danger">@_discoverResult.ErrorMessage</div>
                        }

                        @if (_discoverResult.InternalLinks.Any()) {
                            <h6>Internal Links (@_discoverResult.InternalLinks.Count)</h6>
                            <div class="mb-2">
                                <button type="button" class="btn btn-outline-secondary btn-sm me-1" @onclick="SelectAllDiscovered">Select All</button>
                                <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="SelectNoneDiscovered">Select None</button>
                            </div>
                            <div style="max-height:300px; overflow-y:auto;" class="mb-2">
                                @foreach (var link in _discoverResult.InternalLinks.OrderBy(x => x.Path)) {
                                    <div class="form-check">
                                        <input type="checkbox" class="form-check-input" id="@("disc-" + link.Path.GetHashCode())"
                                               checked="@_selectedDiscoveredPaths.Contains(link.Path)"
                                               @onchange="@(e => ToggleDiscoveredPath(link.Path, (bool)(e.Value ?? false)))" />
                                        <label class="form-check-label" for="@("disc-" + link.Path.GetHashCode())">
                                            <code>@link.Path</code>
                                            @if (!String.IsNullOrEmpty(link.Text)) {
                                                <small class="text-muted ms-1">— @link.Text</small>
                                            }
                                        </label>
                                    </div>
                                }
                            </div>
                            <button type="button" class="btn btn-success btn-sm" @onclick="AddSelectedDiscoveredPages"
                                    disabled="@(!_selectedDiscoveredPaths.Any())">
                                <i class="fas fa-plus"></i> Add Selected (@_selectedDiscoveredPaths.Count)
                            </button>
                        } else if (String.IsNullOrEmpty(_discoverResult.ErrorMessage)) {
                            <p class="text-muted">No new internal links discovered.</p>
                        }

                        @if (_discoverResult.ExternalLinks.Any()) {
                            <h6 class="mt-3">External Links (@_discoverResult.ExternalLinks.Count)</h6>
                            <div class="mb-2">
                                <button type="button" class="btn btn-outline-secondary btn-sm me-1" @onclick="SelectAllDiscoveredExternal">Select All</button>
                                <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="SelectNoneDiscoveredExternal">Select None</button>
                            </div>
                            <div style="max-height:200px; overflow-y:auto;" class="mb-2">
                                @foreach (var link in _discoverResult.ExternalLinks.OrderBy(x => x.Url)) {
                                    <div class="form-check">
                                        <input type="checkbox" class="form-check-input" id="@("disc-ext-" + link.Url.GetHashCode())"
                                               checked="@_selectedDiscoveredExternalUrls.Contains(link.Url)"
                                               @onchange="@(e => ToggleDiscoveredExternalUrl(link.Url, (bool)(e.Value ?? false)))" />
                                        <label class="form-check-label" for="@("disc-ext-" + link.Url.GetHashCode())">
                                            <i class="fas fa-external-link-alt me-1"></i> <code>@link.Url</code>
                                            @if (!String.IsNullOrEmpty(link.Text)) {
                                                <small class="text-muted ms-1">— @link.Text</small>
                                            }
                                        </label>
                                    </div>
                                }
                            </div>
                            <button type="button" class="btn btn-success btn-sm" @onclick="AddSelectedDiscoveredExternalAsSites"
                                    disabled="@(!_selectedDiscoveredExternalUrls.Any())">
                                <i class="fas fa-plus"></i> Add Selected as New Sites (@_selectedDiscoveredExternalUrls.Count)
                            </button>
                        }
                    </div>
                </div>
            }

            @if (_pages.Any()) {
                <table class="table table-sm">
                    <thead>
                        <tr class="table-dark">
                            <th><Language Tag="Path" ReplaceSpaces="true" /></th>
                            <th class="center" style="width:1%;"><Language Tag="RequiresAuth" ReplaceSpaces="true" /></th>
                            <th class="center" style="width:1%;"><Language Tag="Enabled" ReplaceSpaces="true" /></th>
                            <th style="width:80px;"><Language Tag="SortOrder" ReplaceSpaces="true" /></th>
                            <th style="width:1%;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var page in _pages.OrderBy(x => x.SortOrder)) {
                            <tr>
                                <td>
                                    <input type="text" class="form-control form-control-sm" @bind="page.Path" @bind:event="oninput" />
                                </td>
                                <td class="center">
                                    <input type="checkbox" class="form-check-input" @bind="page.RequiresAuth" />
                                </td>
                                <td class="center">
                                    <input type="checkbox" class="form-check-input" @bind="page.Enabled" />
                                </td>
                                <td>
                                    <input type="number" class="form-control form-control-sm" @bind="page.SortOrder" min="0" />
                                </td>
                                <td>
                                    <DeleteConfirmation ButtonSize="xs" OnConfirmed="@(() => DeletePage(page.SitePageId))"
                                                        CancelText="@Helpers.ConfirmButtonTextCancel"
                                                        DeleteText="@Helpers.ConfirmButtonTextDelete"
                                                        ConfirmDeleteText="@Helpers.ConfirmButtonTextConfirmDelete" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            } else {
                <Language Tag="NoItemsToShow" />
            }
        }

        @* ── Credentials Tab ── *@
        @if (_activeTab == "credentials") {
            <div class="mb-2">
                <button type="button" class="btn btn-success btn-sm" @onclick="AddCredential">
                    <Language Tag="AddCredential" IncludeIcon="true" />
                </button>
                <button type="button" class="btn btn-primary btn-sm" @onclick="SaveCredentials">
                    <Language Tag="SaveAll" IncludeIcon="true" />
                </button>
            </div>

            @if (_credentials.Any()) {
                <table class="table table-sm">
                    <thead>
                        <tr class="table-dark">
                            <th><Language Tag="Username" ReplaceSpaces="true" /></th>
                            <th><Language Tag="Password" ReplaceSpaces="true" /></th>
                            <th><Language Tag="AuthType" ReplaceSpaces="true" /></th>
                            <th><Language Tag="TenantCode" ReplaceSpaces="true" /></th>
                            <th style="width:1%;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cred in _credentials) {
                            <tr>
                                <td>
                                    <input type="text" class="form-control form-control-sm" @bind="cred.Username" @bind:event="oninput" />
                                </td>
                                <td>
                                    <input type="password" class="form-control form-control-sm" @bind="cred.PasswordEncrypted" @bind:event="oninput" />
                                </td>
                                <td>
                                    <select class="form-select form-select-sm" @bind="cred.AuthType">
                                        <option value="Standard">Standard</option>
                                        <option value="FreeCRM">FreeCRM</option>
                                        <option value="SSO">SSO</option>
                                    </select>
                                </td>
                                <td>
                                    @if (cred.AuthType == "FreeCRM") {
                                        <input type="text" class="form-control form-control-sm" @bind="cred.TenantCode" @bind:event="oninput" />
                                    }
                                </td>
                                <td>
                                    <DeleteConfirmation ButtonSize="xs" OnConfirmed="@(() => DeleteCredential(cred.SiteCredentialId))"
                                                        CancelText="@Helpers.ConfirmButtonTextCancel"
                                                        DeleteText="@Helpers.ConfirmButtonTextDelete"
                                                        ConfirmDeleteText="@Helpers.ConfirmButtonTextConfirmDelete" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            } else {
                <Language Tag="NoItemsToShow" />
            }
        }

        @* ── Manual Checks Tab ── *@
        @if (_activeTab == "manualchecks") {
            <div class="mb-2">
                <button type="button" class="btn btn-primary btn-sm" @onclick="SaveManualChecks">
                    <Language Tag="SaveAll" IncludeIcon="true" />
                </button>
            </div>

            @if (_manualChecks.Any()) {
                <table class="table table-sm">
                    <thead>
                        <tr class="table-dark">
                            <th style="width:80px;"><Language Tag="Criterion" ReplaceSpaces="true" /></th>
                            <th><Language Tag="Name" ReplaceSpaces="true" /></th>
                            <th style="width:140px;"><Language Tag="Status" ReplaceSpaces="true" /></th>
                            <th><Language Tag="Notes" ReplaceSpaces="true" /></th>
                            <th style="width:120px;"><Language Tag="TestedBy" ReplaceSpaces="true" /></th>
                            <th style="width:140px;"><Language Tag="TestedAt" ReplaceSpaces="true" /></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var check in _manualChecks.OrderBy(x => x.WcagCriterion)) {
                            <tr>
                                <td>@check.WcagCriterion</td>
                                <td>@GetCriterionName(check.WcagCriterion)</td>
                                <td>
                                    <select class="form-select form-select-sm" @bind="check.Status"
                                            @bind:after="@(() => OnManualCheckStatusChanged(check))">
                                        <option value="Not Tested">Not Tested</option>
                                        <option value="Pass">Pass</option>
                                        <option value="Fail">Fail</option>
                                        <option value="N/A">N/A</option>
                                    </select>
                                </td>
                                <td>
                                    <input type="text" class="form-control form-control-sm" @bind="check.Notes" @bind:event="oninput" />
                                </td>
                                <td>@check.TestedBy</td>
                                <td>
                                    @if (check.TestedAt.HasValue) {
                                        @check.TestedAt.Value.ToString("yyyy-MM-dd")
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            } else {
                <Language Tag="NoItemsToShow" />
            }
        }
    }
}
@code {
    [Parameter] public string? SiteId { get; set; }
    [Parameter] public string? TenantCode { get; set; }

    private bool _loading = true;
    private bool _loadedData = false;
    private bool _isNew = false;
    private bool _validatedUrl = false;
    private string _title = "";
    private string _activeTab = "details";
    private string _pageName = "editsite";

    private DataObjects.Site _site = new DataObjects.Site();
    private List<DataObjects.SitePage> _pages = new();
    private List<DataObjects.SiteCredential> _credentials = new();
    private List<DataObjects.ManualCheckResult> _manualChecks = new();
    private bool _scanning = false;
    private DataObjects.ScanProgress? _editScanProgress = null;
    private bool _discoverLoading = false;
    private bool _showDiscoverPanel = false;
    private DataObjects.DiscoverLinksResult? _discoverResult = null;
    private HashSet<string> _selectedDiscoveredPaths = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> _selectedDiscoveredExternalUrls = new(StringComparer.OrdinalIgnoreCase);
    private System.Threading.Timer? _renderTimer;
    private bool _renderPending = false;
    private const int RenderThrottleMs = 300;

    public void Dispose()
    {
        _renderTimer?.Dispose();
        Model.OnChange -= OnDataModelUpdated;
        Model.OnSignalRUpdate -= SignalRUpdate;
    }

    protected override void OnInitialized()
    {
        Model.OnChange += OnDataModelUpdated;
        Model.OnSignalRUpdate += SignalRUpdate;
        Model.View = _pageName;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) {
            Model.TenantCodeFromUrl = TenantCode;
        }

        if (Model.Loaded && Model.LoggedIn) {
            if (!Model.User.Admin) {
                Helpers.NavigateToRoot();
                return;
            }

            if (!_validatedUrl) {
                _validatedUrl = true;
                await Helpers.ValidateUrl(TenantCode);
            }

            if (!_loadedData || Helpers.StringValue(Model.NavigationId) != Helpers.StringValue(SiteId)) {
                _loadedData = true;
                await LoadSite();
            }
        }
    }

    private void OnDataModelUpdated()
    {
        if (Model.View == _pageName) {
            StateHasChanged();
        }
    }

    private async Task LoadSite()
    {
        _loading = true;

        if (SiteId == "new") {
                _isNew = true;
                _title = "AddNewSite";
                Model.NavigationId = SiteId;
                _site = new DataObjects.Site {
                TenantId = Model.TenantId,
                SiteId = Guid.Empty,
                Enabled = true,
                MaxConcurrency = 5,
                PublicVisible = true,
            };
        } else {
            _isNew = false;
            _title = "EditSite";
            Model.NavigationId = SiteId;
            Model.ViewIsEditPage = true;

            Guid siteGuid = Guid.Parse(SiteId!);

            var sites = await Helpers.GetOrPost<List<DataObjects.Site>>("api/Data/GetSites", new List<Guid> { siteGuid });
            if (sites != null && sites.Any()) {
                _site = sites.First();
            }

            // Load child data in parallel
            var pagesTask = Helpers.GetOrPost<List<DataObjects.SitePage>>("api/Data/GetSitePages", new { Ids = new List<Guid>(), SiteId = siteGuid });
            var credsTask = Helpers.GetOrPost<List<DataObjects.SiteCredential>>("api/Data/GetSiteCredentials", new { Ids = new List<Guid>(), SiteId = siteGuid });
            var checksTask = Helpers.GetOrPost<List<DataObjects.ManualCheckResult>>("api/Data/GetManualChecks", new { Ids = new List<Guid>(), SiteId = siteGuid });

            await Task.WhenAll(pagesTask, credsTask, checksTask);

            if (pagesTask.Result != null) _pages = pagesTask.Result;
            if (credsTask.Result != null) _credentials = credsTask.Result;
            if (checksTask.Result != null) _manualChecks = checksTask.Result;
        }

        _loading = false;
        StateHasChanged();
        await Helpers.DelayedFocus("edit-site-Name");
    }

    private async Task Save()
    {
        Model.ClearMessages();

        List<string> errors = new();
        string focus = "";

        if (String.IsNullOrWhiteSpace(_site.Name)) {
            errors.Add(Helpers.MissingRequiredField("Name"));
            if (focus == "") { focus = "edit-site-Name"; }
        }

        if (String.IsNullOrWhiteSpace(_site.BaseUrl)) {
            errors.Add(Helpers.MissingRequiredField("BaseUrl"));
            if (focus == "") { focus = "edit-site-BaseUrl"; }
        }

        if (errors.Any()) {
            Model.ErrorMessages(errors);
            await Helpers.DelayedFocus(focus);
            return;
        }

        Model.Message_Saving();

        var saved = await Helpers.GetOrPost<List<DataObjects.Site>>("api/Data/SaveSites", new List<DataObjects.Site> { _site });

        Model.ClearMessages();

        if (saved != null && saved.Any()) {
            var result = saved.First();
            if (result.ActionResponse.Result) {
                if (_isNew) {
                    Helpers.NavigateTo("Settings/EditSite/" + result.SiteId.ToString());
                } else {
                    _site = result;
                    Model.Message_Saved();
                }
            } else {
                Model.ErrorMessages(result.ActionResponse.Messages);
            }
        } else {
            Model.UnknownError();
        }
    }

    private async Task Delete()
    {
        Model.ClearMessages();
        Model.Message_Deleting();

        var deleted = await Helpers.GetOrPost<DataObjects.BooleanResponse>("api/Data/DeleteSites", new List<Guid> { _site.SiteId });

        Model.ClearMessages();

        if (deleted != null) {
            if (deleted.Result) {
                Helpers.NavigateTo("Settings/Sites");
            } else {
                Model.ErrorMessages(deleted.Messages);
            }
        } else {
            Model.UnknownError();
        }
    }

    // ── Pages Tab ──

    private void AddPage()
    {
        _pages.Add(new DataObjects.SitePage {
            SitePageId = Guid.Empty,
            SiteId = _site.SiteId,
            Path = "/",
            Enabled = true,
            IncludeInScan = true,
            SortOrder = _pages.Count,
        });
    }

    private async Task SavePages()
    {
        Model.ClearMessages();
        Model.Message_Saving();

        foreach (var p in _pages) {
            p.SiteId = _site.SiteId;
        }

        var saved = await Helpers.GetOrPost<List<DataObjects.SitePage>>("api/Data/SaveSitePages", _pages);

        Model.ClearMessages();

        if (saved != null) {
            _pages = saved;
            Model.Message_Saved();
        } else {
            Model.UnknownError();
        }
    }

    private async Task DeletePage(Guid pageId)
    {
        if (pageId == Guid.Empty) {
            _pages = _pages.Where(x => x.SitePageId != pageId).ToList();
            StateHasChanged();
            return;
        }

        Model.ClearMessages();
        Model.Message_Deleting();

        var deleted = await Helpers.GetOrPost<DataObjects.BooleanResponse>("api/Data/DeleteSitePages", new List<Guid> { pageId });

        Model.ClearMessages();

        if (deleted != null && deleted.Result) {
            _pages = _pages.Where(x => x.SitePageId != pageId).ToList();
            StateHasChanged();
        } else {
            Model.UnknownError();
        }
    }

    // ── Credentials Tab ──

    private void AddCredential()
    {
        _credentials.Add(new DataObjects.SiteCredential {
            SiteCredentialId = Guid.Empty,
            SiteId = _site.SiteId,
            TenantId = Model.TenantId,
            AuthType = "Standard",
        });
    }

    private async Task SaveCredentials()
    {
        Model.ClearMessages();
        Model.Message_Saving();

        foreach (var c in _credentials) {
            c.SiteId = _site.SiteId;
            c.TenantId = Model.TenantId;
        }

        var saved = await Helpers.GetOrPost<List<DataObjects.SiteCredential>>("api/Data/SaveSiteCredentials", _credentials);

        Model.ClearMessages();

        if (saved != null) {
            _credentials = saved;
            Model.Message_Saved();
        } else {
            Model.UnknownError();
        }
    }

    private async Task DeleteCredential(Guid credentialId)
    {
        if (credentialId == Guid.Empty) {
            _credentials = _credentials.Where(x => x.SiteCredentialId != credentialId).ToList();
            StateHasChanged();
            return;
        }

        Model.ClearMessages();
        Model.Message_Deleting();

        var deleted = await Helpers.GetOrPost<DataObjects.BooleanResponse>("api/Data/DeleteSiteCredentials", new List<Guid> { credentialId });

        Model.ClearMessages();

        if (deleted != null && deleted.Result) {
            _credentials = _credentials.Where(x => x.SiteCredentialId != credentialId).ToList();
            StateHasChanged();
        } else {
            Model.UnknownError();
        }
    }

