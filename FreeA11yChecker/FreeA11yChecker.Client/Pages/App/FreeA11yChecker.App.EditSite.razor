    private async Task ScanNow()
    {
        _scanning = true;
        _editScanProgress = null;
        StateHasChanged();

        var result = await Helpers.GetOrPost<DataObjects.ScanRun>("api/Data/TriggerScan", _site.SiteId);
        if (result != null && result.ActionResponse != null && !result.ActionResponse.Result) {
            _scanning = false;
            Model.ErrorMessages(result.ActionResponse.Messages);
            StateHasChanged();
        }
    }

    // ── Discover Links ──

    private async Task DiscoverLinks()
    {
        _discoverLoading = true;
        _showDiscoverPanel = false;
        _discoverResult = null;
        _selectedDiscoveredPaths.Clear();
        _selectedDiscoveredExternalUrls.Clear();
        StateHasChanged();

        string baseUrl = _site.BaseUrl.TrimEnd('/');
        string url = baseUrl + "/";
        List<string> additionalUrls = _pages
            .Where(p => !String.IsNullOrWhiteSpace(p.Path) && p.Path != "/")
            .Select(p => baseUrl + (p.Path.StartsWith("/") ? p.Path : "/" + p.Path))
            .ToList();
        var filter = new DataObjects.DiscoverLinksFilter { SiteId = _site.SiteId, Url = url, AdditionalUrls = additionalUrls };
        _discoverResult = await Helpers.GetOrPost<DataObjects.DiscoverLinksResult>("api/Data/DiscoverLinks", filter);

        if (_discoverResult != null) {
            // Pre-select all internal links.
            foreach (var link in _discoverResult.InternalLinks) {
                _selectedDiscoveredPaths.Add(link.Path);
            }
            _showDiscoverPanel = true;
        }

        _discoverLoading = false;
        StateHasChanged();
    }

    private void ToggleDiscoveredPath(string path, bool selected)
    {
        if (selected) {
            _selectedDiscoveredPaths.Add(path);
        } else {
            _selectedDiscoveredPaths.Remove(path);
        }
    }

    private void SelectAllDiscovered()
    {
        if (_discoverResult != null) {
            foreach (var link in _discoverResult.InternalLinks) {
                _selectedDiscoveredPaths.Add(link.Path);
            }
        }
    }

    private void SelectNoneDiscovered()
    {
        _selectedDiscoveredPaths.Clear();
    }

    private async Task AddSelectedDiscoveredPages()
    {
        if (_discoverResult == null || !_selectedDiscoveredPaths.Any()) return;

        int sortOrder = _pages.Count;
        List<DataObjects.SitePage> newPages = new();

        foreach (string path in _selectedDiscoveredPaths) {
            sortOrder++;
            newPages.Add(new DataObjects.SitePage {
                SitePageId = Guid.Empty,
                SiteId = _site.SiteId,
                Path = path,
                Enabled = true,
                IncludeInScan = true,
                SortOrder = sortOrder,
            });
        }

        Model.ClearMessages();
        Model.Message_Saving();

        var saved = await Helpers.GetOrPost<List<DataObjects.SitePage>>("api/Data/SaveSitePages", newPages);

        Model.ClearMessages();

        if (saved != null) {
            _pages.AddRange(saved);
            _showDiscoverPanel = false;
            Model.Message_Saved();
        } else {
            Model.UnknownError();
        }
    }

    private void ToggleDiscoveredExternalUrl(string url, bool selected)
    {
        if (selected) {
            _selectedDiscoveredExternalUrls.Add(url);
        } else {
            _selectedDiscoveredExternalUrls.Remove(url);
        }
    }

    private void SelectAllDiscoveredExternal()
    {
        if (_discoverResult != null) {
            foreach (var link in _discoverResult.ExternalLinks) {
                _selectedDiscoveredExternalUrls.Add(link.Url);
            }
        }
    }

    private void SelectNoneDiscoveredExternal()
    {
        _selectedDiscoveredExternalUrls.Clear();
    }

    private async Task AddSelectedDiscoveredExternalAsSites()
    {
        if (_discoverResult == null || !_selectedDiscoveredExternalUrls.Any()) return;

        List<DataObjects.Site> newSites = new();

        foreach (string url in _selectedDiscoveredExternalUrls) {
            string name = url;
            try {
                name = new Uri(url).Host;
            } catch { }

            newSites.Add(new DataObjects.Site {
                SiteId = Guid.Empty,
                TenantId = Model.TenantId,
                Name = name,
                BaseUrl = url,
                Enabled = false,
                MaxConcurrency = 5,
                PublicVisible = true,
            });
        }

        Model.ClearMessages();
        Model.Message_Saving();

        var saved = await Helpers.GetOrPost<List<DataObjects.Site>>("api/Data/SaveSites", newSites);

        Model.ClearMessages();

        if (saved != null) {
            // Remove added URLs from the local discovered-external list so they don't appear duplicated.
            var addedUrls = new HashSet<string>(_selectedDiscoveredExternalUrls, StringComparer.OrdinalIgnoreCase);
            _discoverResult.ExternalLinks = _discoverResult.ExternalLinks
                .Where(x => !addedUrls.Contains(x.Url))
                .ToList();
            _selectedDiscoveredExternalUrls.Clear();
            Model.Message_Saved();
        } else {
            Model.UnknownError();
        }
    }

    private void SignalRUpdate(DataObjects.SignalRUpdate update)
    {
        if (Model.View != _pageName || _site == null) { return; }

        if (update.UpdateType == DataObjects.SignalRUpdateType.ScanProgress && update.Object != null) {
            try {
                var json = System.Text.Json.JsonSerializer.Serialize(update.Object);
                var progress = System.Text.Json.JsonSerializer.Deserialize<DataObjects.ScanProgress>(json,
                    new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                if (progress != null && progress.SiteId == _site.SiteId) {
                    _scanning = true;
                    _editScanProgress = progress;
                    RequestThrottledRender();
                }
            } catch { }
        } else if (update.UpdateType == DataObjects.SignalRUpdateType.ScanComplete ||
                   update.UpdateType == DataObjects.SignalRUpdateType.ScanFailed) {
            if (update.Object == null) { return; }
            try {
                var json = System.Text.Json.JsonSerializer.Serialize(update.Object);
                var scanRun = System.Text.Json.JsonSerializer.Deserialize<DataObjects.ScanRun>(json,
                    new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                if (scanRun == null || scanRun.SiteId != _site.SiteId) { return; }

                // Update site summary from event payload — no full reload needed.
                _site.LastScanAt = scanRun.StartedAt;
                _site.LastScanStatus = scanRun.Status;
                _site.LastViolationCount = scanRun.TotalViolations;
                _site.LastCriticalCount = scanRun.CriticalCount;
                _site.LastScanRunId = scanRun.ScanRunId;
                _scanning = false;
                _editScanProgress = null;

                InvokeAsync(StateHasChanged);
            } catch { }
        }
    }

    private void RequestThrottledRender()
    {
        if (_renderPending) return;
        _renderPending = true;
        _renderTimer?.Dispose();
        _renderTimer = new System.Threading.Timer(_ => {
            _renderPending = false;
            InvokeAsync(StateHasChanged);
        }, null, RenderThrottleMs, System.Threading.Timeout.Infinite);
    }
