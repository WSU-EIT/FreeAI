    private void SignalRUpdate(DataObjects.SignalRUpdate update)
    {
        if (Model.View != _pageName) { return; }

        if (update.UpdateType == DataObjects.SignalRUpdateType.ScanLog && update.Object != null) {
            try {
                var json = System.Text.Json.JsonSerializer.Serialize(update.Object);
                var logEntry = System.Text.Json.JsonSerializer.Deserialize<DataObjects.ScanLogEntry>(json,
                    new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                if (logEntry != null && _site != null && logEntry.SiteId == _site.SiteId) {
                    _logEntries.Add(logEntry);
                    RequestThrottledRender();
                }
            } catch { }
        } else if (update.UpdateType == DataObjects.SignalRUpdateType.ScanProgress && update.Object != null) {
            try {
                var json = System.Text.Json.JsonSerializer.Serialize(update.Object);
                var progress = System.Text.Json.JsonSerializer.Deserialize<DataObjects.ScanProgress>(json,
                    new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                if (progress != null && _site != null && progress.SiteId == _site.SiteId) {
                    _scanning = true;
                    _currentProgress = progress;
                    RequestThrottledRender();
                }
            } catch { }
        } else if (update.UpdateType == DataObjects.SignalRUpdateType.ScanComplete && update.Object != null) {
            if (_site == null) { return; }
            try {
                var json = System.Text.Json.JsonSerializer.Serialize(update.Object);
                var scanRun = System.Text.Json.JsonSerializer.Deserialize<DataObjects.ScanRun>(json,
                    new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                if (scanRun == null || scanRun.SiteId != _site.SiteId) { return; }

                _scanning = false;
                _currentProgress = null;
                UpdateOrAddRun(scanRun);
                InvokeAsync(StateHasChanged);
            } catch { }
        } else if (update.UpdateType == DataObjects.SignalRUpdateType.ScanFailed && update.Object != null) {
            if (_site == null) { return; }
            try {
                var json = System.Text.Json.JsonSerializer.Serialize(update.Object);
                var scanRun = System.Text.Json.JsonSerializer.Deserialize<DataObjects.ScanRun>(json,
                    new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                if (scanRun == null || scanRun.SiteId != _site.SiteId) { return; }

                _scanning = false;
                _currentProgress = null;
                UpdateOrAddRun(scanRun);
                InvokeAsync(StateHasChanged);
            } catch { }
        }
    }

    private void UpdateOrAddRun(DataObjects.ScanRun scanRun)
    {
        var existing = _runs.FirstOrDefault(r => r.ScanRunId == scanRun.ScanRunId);
        if (existing != null) {
            existing.Status = scanRun.Status;
            existing.CompletedAt = scanRun.CompletedAt;
            existing.TotalPages = scanRun.TotalPages;
            existing.PagesScanned = scanRun.PagesScanned;
            existing.TotalViolations = scanRun.TotalViolations;
            existing.CriticalCount = scanRun.CriticalCount;
            existing.SeriousCount = scanRun.SeriousCount;
            existing.ModerateCount = scanRun.ModerateCount;
            existing.MinorCount = scanRun.MinorCount;
        } else {
            _runs.Insert(0, scanRun);
        }
    }

    private void RequestThrottledRender()
    {
        if (_renderPending) return;
        _renderPending = true;
        _renderTimer?.Dispose();
        _renderTimer = new System.Threading.Timer(_ => {
            _renderPending = false;
            InvokeAsync(StateHasChanged);
        }, null, RenderThrottleMs, System.Threading.Timeout.Infinite);
    }
}
