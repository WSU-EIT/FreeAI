{
  // FreeCodeMaid rule set. Copy this into a target repo's root (next to the .sln / .editorconfig)
  // and FreeCodeMaid will pick it up automatically. Comments and trailing commas are allowed.
  // The values below are the built-in defaults, tuned to the FreeCRM house convention.

  // --- Sorting behavior ---
  "SortAlphabetically": true,          // sort members alphabetically within each kind group
  "IgnoreLeadingUnderscoreInSort": true, // "_connectionString" sorts as "connectionString"; "data" slots in by bare name
  "GroupByVisibility": false,          // FreeCRM interleaves public/private methods alphabetically; set true for CodeMaid-style access grouping
  "StaticMembersFirst": false,         // set true to float static members to the top of each kind group

  // --- Spacing (only applied to types that are actually reordered) ---
  "BlankLinesBetweenMembers": 1,       // blank lines between block members / across kind changes
  "BlankLinesBetweenFields": 0,        // consecutive single-line members of the same kind stay dense (field block, simple auto-prop DTOs)

  // --- Ordering tables ---
  // Member kinds are emitted top-to-bottom in this order.
  "KindOrder": [
    "Const", "Field", "Constructor", "Destructor", "Delegate", "Event",
    "Enum", "Interface", "Property", "Indexer", "Operator", "ConversionOperator",
    "Method", "Struct", "Class", "Record"
  ],
  // Used only when GroupByVisibility = true.
  "VisibilityOrder": [
    "public", "internal", "protected internal", "protected", "private protected", "private"
  ],
  // These kinds keep their original relative order (never alphabetized) — order is meaningful to humans.
  "DoNotSortKinds": [ "Constructor", "Destructor", "Operator", "ConversionOperator" ],

  // --- Safety / scope ---
  "SkipTypesWithDirectives": true,     // never reorder across #region / #if / #pragma (would scramble them)
  "SkipAutoGenerated": true,           // skip files whose header marks them machine-generated

  // Directories/files never even read (build output, vendored, generated).
  "Exclude": [
    "**/bin/**", "**/obj/**", "**/.git/**", "**/.vs/**",
    "**/node_modules/**", "**/packages/**",
    "**/wwwroot/lib/**", "**/wwwroot/js/**", "**/wwwroot/fontawesome/**",
    "**/EFModels/**", "**/DynamicBlazorSupport/**"
  ],

  // Valid hand-written source whose member ORDER is intentional ("by-purpose") or generated —
  // reported as skipped, never reorganized.
  "SkipFiles": [
    "**/*.Designer.cs", "**/*.g.cs", "**/*.g.i.cs",
    "**/*.AssemblyInfo.cs", "**/*.GlobalUsings.g.cs", "**/GlobalUsings.cs",
    // FreeCRM by-purpose files: DTOs lead with primary key + TenantId and group audit fields;
    // the DataController root holds a deliberate (non-alphabetical) field block.
    "**/DataObjects*.cs", "**/DataController.cs"
  ]
}
