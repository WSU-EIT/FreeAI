{
  // FreeCodeMaid rule set. Copy this into a target repo's root (next to the .sln / .editorconfig)
  // and FreeCodeMaid picks it up automatically. Comments and trailing commas are allowed.
  // These values are the built-in defaults, CALIBRATED so that running the tool against FreeCRM
  // changes as little as possible: it matches the author's convention and only tidies real slips.

  // --- Sorting behavior ---
  "SortAlphabetically": true,            // sort the sortable kinds alphabetically within their group
  "IgnoreLeadingUnderscoreInSort": true, // "_connectionString" sorts as "connectionString"
  "GroupByVisibility": false,            // FreeCRM interleaves public/private; true = CodeMaid-style access grouping
  "StaticMembersFirst": false,           // true floats static members to the top of their group

  // The key "minimal change" guard: if sorting would move more than this fraction of a type's
  // sortable members, the type is treated as deliberately ordered BY PURPOSE and left untouched.
  // This auto-skips controllers, nested DTOs, plugin examples, etc. Set to 1.0 to always sort.
  "MaxFractionReordered": 0.35,

  // --- Ordering tables ---
  // Member kinds are emitted top-to-bottom in this order. Entries may list several kinds separated
  // by commas; kinds in one entry share a rank and sort TOGETHER. The default reproduces the FreeCRM
  // convention: fields stay grouped at the top in their original (by-purpose) order, and
  // properties + indexers + methods form one interleaved alphabetical list.
  "KindOrder": [
    "Const",
    "Field",
    "Constructor,Destructor",
    "Delegate,Event",
    "Property,Indexer,Method",
    "Operator,ConversionOperator",
    "Enum,Interface,Struct,Class,Record"
  ],

  // Used only when GroupByVisibility = true.
  "VisibilityOrder": [
    "public", "internal", "protected internal", "protected", "private protected", "private"
  ],

  // Kinds left in their original relative order (never alphabetized). By default only properties,
  // indexers and methods are sorted; everything else is preserved as written. Note Field/Const:
  // the author groups fields by purpose (services, then state), so we must NOT reorder them.
  "DoNotSortKinds": [
    "Const", "Field", "Constructor", "Destructor", "Delegate", "Event",
    "Operator", "ConversionOperator", "Enum", "Interface", "Struct", "Class", "Record"
  ],

  // --- Safety / scope ---
  "SkipTypesWithDirectives": true,       // never reorder across #region / #if / #pragma
  "SkipAutoGenerated": true,             // skip files whose header marks them machine-generated

  // Directories/files never even read (build output, vendored, generated).
  "Exclude": [
    "**/bin/**", "**/obj/**", "**/.git/**", "**/.vs/**",
    "**/node_modules/**", "**/packages/**",
    "**/wwwroot/lib/**", "**/wwwroot/js/**", "**/wwwroot/fontawesome/**",
    "**/EFModels/**", "**/DynamicBlazorSupport/**"
  ],

  // Valid source whose member ORDER is intentional ("by-purpose") or generated — never reorganized.
  // (The MaxFractionReordered guard catches most by-purpose types automatically; these are explicit.)
  "SkipFiles": [
    "**/*.Designer.cs", "**/*.g.cs", "**/*.g.i.cs",
    "**/*.AssemblyInfo.cs", "**/*.GlobalUsings.g.cs", "**/GlobalUsings.cs",
    "**/DataObjects*.cs", "**/DataController.cs"
  ]
}
