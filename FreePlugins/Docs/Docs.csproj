<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>FreePlugins.Docs</RootNamespace>
    <AssemblyName>FreePlugins.Docs</AssemblyName>
    <!-- Documentation and showcase outputs only, no compilable code -->
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
  </PropertyGroup>

  <ItemGroup>
    <None Include="showcase\**\*" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
